<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}Tranzo – P2P File Transfer{% endblock %}</title>
  <meta name="description" content="{% block metaDesc %}Transfer files directly between devices for free using WebRTC. No cloud, no signup, no limits. 100% private P2P file sharing.{% endblock %}" />

  <!-- Canonical URL — each page overrides this block -->
  {% block canonical %}<link rel="canonical" href="{{ siteUrl }}/" />{% endblock %}

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Tranzo" />
  <meta property="og:title"       content="{% block ogTitle %}Tranzo – P2P File Transfer{% endblock %}" />
  <meta property="og:description" content="{% block ogDesc %}Transfer files directly between devices for free using WebRTC. 100% private, no signup.{% endblock %}" />
  <meta property="og:url"         content="{% block ogUrl %}{{ siteUrl }}/{% endblock %}" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary" />
  <meta name="twitter:title"       content="{% block twitterTitle %}Tranzo – P2P File Transfer{% endblock %}" />
  <meta name="twitter:description" content="{% block twitterDesc %}Free, private WebRTC file transfers. No cloud, no signup.{% endblock %}" />

  <!-- Bootstrap 5.3.3 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&display=swap" rel="stylesheet"/>

  <style>
    /* ================================================
       TRANZO  --  WHITE + EMERALD + AMBER
    ================================================ */
    :root {
      --bg:        #FFFFFF;
      --surface:   #F8FAFB;
      --surfaceHi: #EEF2F5;

      --border:    rgba(17,24,39,.1);
      --borderHi:  rgba(17,24,39,.2);
      --borderEm:  rgba(5,150,105,.3);
      --borderAmb: rgba(217,119,6,.3);

      --text:   #111827;
      --muted:  #4B5563;
      --muted2: #9CA3AF;

      --em:      #059669;
      --emDark:  #047857;
      --emLight: #D1FAE5;
      --emGlow:  rgba(5,150,105,.18);

      --amb:      #D97706;
      --ambDark:  #B45309;
      --ambLight: #FEF3C7;
      --ambGlow:  rgba(217,119,6,.15);

      --rose:      #EF4444;
      --roseLight: #FEE2E2;

      --success: #059669;

      --r:   14px;
      --rSm: 9px;
      --rXs: 6px;

      --shadow-sm: 0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md: 0 4px 16px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);
      --shadow-lg: 0 12px 40px rgba(0,0,0,.1),  0 4px 12px rgba(0,0,0,.06);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Subtle background decoration */
    .bg-canvas {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
    }
    .bg-canvas::before {
      content: "";
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 900px 600px at 10%  0%,  rgba(5,150,105,.05), transparent 60%),
        radial-gradient(ellipse 700px 500px at 90% 100%, rgba(217,119,6,.04),  transparent 55%),
        radial-gradient(ellipse 600px 400px at 50%  50%, rgba(5,150,105,.03),  transparent 65%);
      animation: bgDrift 24s ease-in-out infinite alternate;
    }
    @keyframes bgDrift {
      0%   { transform: scale(1)    translate(0,0); }
      50%  { transform: scale(1.03) translate(-8px, 6px); }
      100% { transform: scale(1.02) translate(8px,-5px); }
    }
    .bg-canvas::after {
      content: "";
      position: absolute; inset: 0;
      background-image: radial-gradient(circle, rgba(17,24,39,.055) 1px, transparent 1px);
      background-size: 28px 28px;
    }

    .page-wrap {
      position: relative; z-index: 1;
      min-height: 100vh;
      display: flex; flex-direction: column;
    }

    /* ================================================
       NAVBAR  —  Bootstrap navbar pattern
    ================================================ */
    .nav-bar {
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 200;
      padding: 0;
    }

    .nav-inner {
      height: 62px;
      display: flex; align-items: center; justify-content: space-between;
    }

    .nav-logo {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 800; font-size: 1.25rem; letter-spacing: -.03em;
      text-decoration: none; color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .nav-logo-icon {
      width: 32px; height: 32px; border-radius: 9px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--em), var(--emDark));
      display: flex; align-items: center; justify-content: center;
      font-size: 15px;
      box-shadow: 0 2px 10px var(--emGlow);
    }
    .nav-logo .dot { color: var(--em); }

    .nav-right { display: flex; align-items: center; gap: 10px; }

    /* Badge: min 12px, darkened for contrast on light bg */
    .nav-badge {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 12px; font-weight: 700; letter-spacing: .6px;
      text-transform: uppercase; padding: 3px 10px; border-radius: 999px;
      background: var(--emLight); color: var(--emDark);
      border: 1px solid rgba(5,150,105,.3);
    }

    .conn-pill {
      display: flex; align-items: center; gap: 7px;
      background: var(--surface);
      border: 1px solid var(--border); border-radius: 999px;
      padding: 5px 12px 5px 9px;
      box-shadow: var(--shadow-sm);
    }
    .conn-dot {
      width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
      background: var(--rose);
      box-shadow: 0 0 0 2px rgba(239,68,68,.18);
      transition: all .4s;
    }
    .conn-dot.green {
      background: var(--em);
      box-shadow: 0 0 0 2px rgba(5,150,105,.2), 0 0 6px var(--emGlow);
      animation: dotPulse 2.5s infinite;
    }
    @keyframes dotPulse {
      0%,100% { box-shadow: 0 0 0 2px rgba(5,150,105,.2), 0 0 6px var(--emGlow); }
      50%      { box-shadow: 0 0 0 4px rgba(5,150,105,.1), 0 0 12px var(--emGlow); }
    }
    #status { font-size: 13px; color: var(--muted); font-weight: 600; white-space: nowrap; }

    /* ================================================
       HERO  --  collapses after Create / Join
    ================================================ */
    .hero {
      text-align: center;
      padding: 72px 0 52px;
      transition: padding .5s cubic-bezier(.4,0,.2,1);
    }
    .hero.hero-compact { padding: 28px 0 20px; }

    /* All hero children collapse via max-height — stay in DOM for SEO */
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px; font-weight: 700; letter-spacing: .5px;
      text-transform: uppercase; color: var(--ambDark);
      border: 1px solid var(--borderAmb); padding: 6px 16px;
      border-radius: 999px; margin-bottom: 20px;
      background: var(--ambLight);
      overflow: hidden; max-height: 56px; opacity: 1;
      transition: max-height .45s ease, opacity .3s ease, margin .4s ease;
    }
    .hero.hero-compact .hero-eyebrow { max-height: 0; opacity: 0; margin-bottom: 0; }

    .hero h1 {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 800;
      font-size: clamp(1.9rem, 5vw, 3.4rem);
      line-height: 1.08; letter-spacing: -.03em;
      color: var(--text); margin-bottom: 16px;
      transition: font-size .45s ease, margin .4s ease;
    }
    .hero.hero-compact h1 {
      font-size: clamp(1.15rem, 3vw, 1.5rem);
      margin-bottom: 0;
    }
    .hero h1 .grad {
      background: linear-gradient(100deg, var(--em) 0%, #10B981 45%, var(--amb) 100%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }

    .hero-sub {
      font-size: 1rem; color: var(--muted);
      max-width: 440px; margin: 0 auto 28px; line-height: 1.75;
      overflow: hidden; max-height: 100px; opacity: 1;
      transition: max-height .45s ease, opacity .3s ease, margin .4s ease;
    }
    .hero.hero-compact .hero-sub { max-height: 0; opacity: 0; margin-bottom: 0; }

    .trust-badges {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 8px;
      overflow: hidden; max-height: 80px; opacity: 1;
      transition: max-height .4s ease, opacity .3s ease;
    }
    .hero.hero-compact .trust-badges { max-height: 0; opacity: 0; }

    .trust-badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 13px; font-weight: 600; color: var(--muted);
      background: var(--surface); border: 1px solid var(--border);
      padding: 6px 14px; border-radius: 999px;
      box-shadow: var(--shadow-sm);
      transition: border-color .2s, color .2s;
    }
    .trust-badge:hover { border-color: var(--borderEm); color: var(--em); }

    /* ================================================
       CARD
    ================================================ */
    .g-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r);
      margin-bottom: 16px;
      overflow: hidden; position: relative;
      transition: border-color .25s, box-shadow .25s;
      box-shadow: var(--shadow-sm);
    }
    .g-card:hover { border-color: var(--borderHi); box-shadow: var(--shadow-md); }
    .g-card.strip-em  { border-top: 2px solid var(--em); }
    .g-card.strip-amb { border-top: 2px solid var(--amb); }
    .g-card-body { padding: 22px 24px; }

    /* ================================================
       PROGRESSIVE REVEAL
       Elements in DOM always (SEO safe, no layout shift).
    ================================================ */
    .reveal-panel {
      overflow: hidden;
      max-height: 0; opacity: 0; transform: translateY(-6px);
      pointer-events: none;
      transition:
        max-height .55s cubic-bezier(.4,0,.2,1),
        opacity    .4s  cubic-bezier(.4,0,.2,1),
        transform  .45s cubic-bezier(.4,0,.2,1);
    }
    .reveal-panel.is-visible {
      max-height: 1600px; opacity: 1; transform: translateY(0);
      pointer-events: auto;
    }
    #shareLinkPanel { transition-delay: 0s,   0s,   0s;   }
    #membersPanel   { transition-delay: .04s, .04s, .04s; }
    #chatPanel      { transition-delay: .08s, .08s, .08s; }
    #scorePanel     { transition-delay: .12s, .12s, .12s; }
    #filePanel      { transition-delay: .16s, .16s, .16s; }

    /* ================================================
       SECTION LABEL
    ================================================ */
    .section-label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 12px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: #6B7280;
      margin-bottom: 16px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-label::after { content: ""; flex: 1; height: 1px; background: var(--border); }

    /* ================================================
       INPUTS
    ================================================ */
    .field-label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px; font-weight: 600; letter-spacing: .3px;
      text-transform: uppercase; color: var(--muted);
      margin-bottom: 6px; display: block;
    }
    .g-input {
      background: var(--surface) !important;
      border: 1px solid var(--border) !important;
      border-radius: var(--rSm) !important;
      color: var(--text) !important;
      font-family: 'Plus Jakarta Sans', sans-serif !important;
      font-size: 15px !important;
      padding: 11px 14px !important;
      transition: border-color .2s, box-shadow .2s, background .2s;
      width: 100%; outline: none;
    }
    .g-input::placeholder { color: #6B7280 !important; }
    .g-input:focus {
      border-color: var(--borderEm) !important;
      box-shadow: 0 0 0 3px rgba(5,150,105,.1) !important;
      background: #fff !important;
    }

    /* ================================================
       BUTTONS
    ================================================ */
    .btn-em {
      background: linear-gradient(135deg, var(--em) 0%, var(--emDark) 100%);
      color: #fff !important; border: none !important;
      border-radius: var(--rSm) !important;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700; font-size: 15px;
      padding: 11px 22px; cursor: pointer;
      transition: transform .18s, box-shadow .2s, filter .18s;
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      position: relative; overflow: hidden; white-space: nowrap;
    }
    .btn-em::before {
      content: ""; position: absolute;
      top: 0; left: -100%; width: 55%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.2), transparent);
      transition: left .45s;
    }
    .btn-em:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 18px var(--emGlow), 0 2px 8px rgba(0,0,0,.1);
      filter: brightness(1.06); color: #fff !important;
    }
    .btn-em:hover::before { left: 140%; }
    .btn-em:active { transform: none; }

    .btn-ghost {
      background: #fff !important; color: var(--text) !important;
      border: 2px solid var(--borderHi) !important;
      border-radius: var(--rSm) !important;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600; font-size: 15px;
      padding: 11px 22px; cursor: pointer;
      transition: background .18s, border-color .18s, transform .18s, box-shadow .18s;
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      box-shadow: var(--shadow-sm);
    }
    .btn-ghost:hover {
      background: var(--surface) !important;
      border-color: var(--borderEm) !important;
      transform: translateY(-1px); color: var(--text) !important;
    }

    .btn-amb {
      background: linear-gradient(135deg, var(--amb), var(--ambDark)) !important;
      color: #fff !important; font-weight: 700 !important;
      border: none !important;
      border-radius: var(--rSm) !important;
      font-family: 'Space Grotesk', sans-serif; font-size: 15px;
      padding: 11px 20px; cursor: pointer;
      transition: transform .18s, box-shadow .2s;
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      white-space: nowrap;
    }
    .btn-amb:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px var(--ambGlow); color: #fff !important;
    }

    .btn-danger {
      background: var(--roseLight) !important; color: #B91C1C !important;
      border: 1px solid rgba(239,68,68,.3) !important;
      border-radius: var(--rSm) !important;
      font-family: 'Space Grotesk', sans-serif; font-size: 15px;
      font-weight: 600; padding: 11px 22px; cursor: pointer;
      transition: background .18s, border-color .18s;
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    }
    .btn-danger:hover {
      background: rgba(239,68,68,.15) !important;
      border-color: rgba(239,68,68,.4) !important; color: #B91C1C !important;
    }

    /* Small button variant */
    .btn-sm-custom {
      padding: 8px 14px !important;
      font-size: 13px !important;
      border-radius: var(--rXs) !important;
    }
    /* Full-width on xs */
    @media (max-width: 575.98px) {
      .btn-em, .btn-ghost { width: 100%; }
    }

    #roomHint { font-size: 13px; color: var(--em); font-weight: 600; margin-top: 8px; }

    /* ================================================
       SHARE LINK
    ================================================ */
    .link-icon-wrap {
      width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
      background: var(--emLight); border: 1px solid rgba(5,150,105,.2);
      display: flex; align-items: center; justify-content: center; font-size: 18px;
    }
    .link-title {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700; font-size: 15px; color: var(--text);
    }
    .link-sub { font-size: 13px; color: var(--muted); margin-top: 2px; }

    #shareLinkInput {
      background: var(--surface) !important;
      border: 1px solid var(--border) !important;
      border-right: none !important;
      border-radius: var(--rXs) 0 0 var(--rXs) !important;
      color: var(--text) !important;
      font-family: 'Courier New', monospace !important;
      font-size: 13px !important;
      padding: 10px 14px !important;
      flex: 1; outline: none; min-width: 0;
    }
    #shareLinkInput:focus {
      border-color: var(--borderEm) !important;
      box-shadow: 0 0 0 3px rgba(5,150,105,.08) !important;
    }
    .copy-attached { border-radius: 0 var(--rXs) var(--rXs) 0 !important; }

    /* ================================================
       CHAT
    ================================================ */
    #chatBox {
      height: 200px !important; overflow-y: auto;
      background: var(--surface) !important;
      border: 1px solid var(--border) !important;
      border-radius: var(--rSm) !important;
      padding: 12px !important;
      scrollbar-width: thin;
      scrollbar-color: rgba(17,24,39,.12) transparent;
    }
    #chatBox::-webkit-scrollbar { width: 4px; }
    #chatBox::-webkit-scrollbar-thumb { background: rgba(17,24,39,.12); border-radius: 4px; }
    .msg {
      padding: 9px 13px; border-radius: 9px; margin-bottom: 8px;
      background: #fff; border: 1px solid var(--border);
      font-size: 14px; line-height: 1.6; color: var(--text);
      box-shadow: var(--shadow-sm);
    }

    /* ================================================
       DROP ZONE
    ================================================ */
    .drop-zone {
      border: 2px dashed rgba(5,150,105,.25);
      border-radius: var(--r);
      padding: 36px 16px; text-align: center; cursor: pointer;
      background: rgba(5,150,105,.02);
      position: relative; overflow: hidden;
      transition: border-color .25s, background .25s, box-shadow .25s;
    }
    .drop-zone:hover, .drop-zone.dragover {
      border-color: var(--em); background: var(--emLight);
      box-shadow: 0 0 0 4px rgba(5,150,105,.07);
    }
    .drop-zone input[type="file"] {
      position: absolute; inset: 0; width: 100%; height: 100%;
      opacity: 0; cursor: pointer; z-index: 2;
    }
    .drop-icon-wrap {
      width: 64px; height: 64px; border-radius: 16px; margin: 0 auto 14px;
      background: var(--emLight); border: 1px solid rgba(5,150,105,.2);
      display: flex; align-items: center; justify-content: center; font-size: 1.8rem;
      box-shadow: 0 4px 14px var(--emGlow);
      transition: transform .25s, box-shadow .25s;
    }
    .drop-zone:hover .drop-icon-wrap, .drop-zone.dragover .drop-icon-wrap {
      transform: translateY(-4px) scale(1.06);
      box-shadow: 0 8px 24px var(--emGlow);
    }
    .drop-icon { font-size: 2rem; display: block; }
    .drop-title {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700; font-size: 16px; color: var(--text); margin-bottom: 6px;
    }
    .drop-sub {
      font-size: 14px; color: var(--muted);
      max-width: 320px; margin: 0 auto; line-height: 1.6;
    }
    .dz-divider {
      display: flex; align-items: center; gap: 10px;
      margin: 14px auto; max-width: 160px;
      font-size: 13px; font-weight: 600; color: #6B7280;
    }
    .dz-divider::before, .dz-divider::after { content: ""; flex: 1; height: 1px; background: var(--border); }

    /* ================================================
       PROGRESS
    ================================================ */
    .progress-rail {
      width: 100%; height: 6px;
      background: var(--surface); border-radius: 999px; overflow: hidden;
      border: 1px solid var(--border);
    }
    .progress-fill {
      height: 100%; border-radius: 999px; width: 0%;
      background: linear-gradient(90deg, var(--em), #10B981, var(--amb));
      background-size: 200% 100%;
      box-shadow: 0 0 6px var(--emGlow);
      transition: width .35s ease;
      animation: barShimmer 2.5s linear infinite;
    }
    @keyframes barShimmer {
      0%   { background-position: 200% center; }
      100% { background-position: -200% center; }
    }
    progress#progressBar { display: none !important; }

    .stat-pill {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--rXs); padding: 6px 10px;
      font-size: 13px; font-weight: 500; color: var(--muted);
      display: inline-flex; align-items: center; gap: 4px;
    }
    .stat-pill b { color: var(--text); font-weight: 700; }

    #fileStatus {
      font-size: 14px; color: var(--muted); font-weight: 500;
      display: flex; align-items: center; gap: 7px;
    }
    .g-divider { height: 1px; background: var(--border); margin: 16px 0; }

    /* ================================================
       MODAL
    ================================================ */
    #modalBg {
      position: fixed; inset: 0;
      background: rgba(17,24,39,.45);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      display: none; align-items: center; justify-content: center;
      z-index: 1050; padding: 16px;
    }
    #modal {
      background: #fff !important;
      border: 1px solid var(--border) !important;
      border-radius: 18px !important; padding: 24px !important;
      width: min(500px, 100%);
      box-shadow: var(--shadow-lg) !important;
      position: relative; overflow: hidden;
      animation: modalIn .22s cubic-bezier(.2,.8,.2,1);
    }
    @keyframes modalIn {
      from { opacity:0; transform:scale(.96) translateY(8px); }
      to   { opacity:1; transform:none; }
    }
    #modal::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--em), #10B981, var(--amb));
    }
    #modal .h5 {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700; font-size: 17px; color: var(--text); margin-bottom: 12px;
    }
    #modal pre {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--rXs); padding: 12px;
      font-size: 14px; color: var(--muted); white-space: pre-wrap;
    }

    /* ================================================
       FOOTER  (expanded version)
    ================================================ */
    .page-footer {
      border-top: 1px solid var(--border);
      background: var(--surface);
      position: relative; z-index: 1;
    }
    .footer-name {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700; font-size: 15px; color: var(--em);
    }
    .footer-tag   { font-size: 13px; color: var(--muted); }
    .footer-icon {
      width: 24px; height: 24px; border-radius: 6px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--em), var(--emDark));
      display: flex; align-items: center; justify-content: center; font-size: 11px;
    }
    .footer-links a {
      font-size: 13px; font-weight: 500; color: var(--muted);
      text-decoration: none; transition: color .2s;
    }
    .footer-links a:hover { color: var(--em); }

    /* ── Extended footer columns ── */
    .footer-col-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--muted2);
      margin-bottom: 12px;
    }
    .footer-col-links { list-style: none; padding: 0; margin: 0; }
    .footer-col-links li { margin-bottom: 8px; }
    .footer-col-links a {
      font-size: 13px; font-weight: 500; color: var(--muted);
      text-decoration: none; transition: color .2s;
    }
    .footer-col-links a:hover { color: var(--em); }
    .footer-bottom {
      border-top: 1px solid var(--border);
      padding: 14px 0;
      font-size: 12px; color: var(--muted2);
    }

    /* ================================================
       AD SLOTS
       — placeholder iframes for Google AdSense.
         Replace src="" with your actual ad unit URLs
         once your site is approved.
    ================================================ */
    .ad-slot {
      display: block; width: 100%; overflow: hidden;
      border-radius: var(--rSm);
      background: var(--surfaceHi);
      border: 1px dashed var(--border);
      text-align: center; color: var(--muted2);
      font-size: 12px; font-weight: 500;
      position: relative;
    }
    .ad-slot iframe {
      display: block; border: none; width: 100%;
    }
    /* Leaderboard — top of content pages: 728×90, collapses on mobile */
    .ad-slot-leaderboard { min-height: 90px; }
    .ad-slot-leaderboard iframe { height: 90px; max-width: 728px; margin: 0 auto; }
    /* Rectangle — sidebar / in-content: 300×250 */
    .ad-slot-rect { min-height: 250px; max-width: 336px; margin: 0 auto; }
    .ad-slot-rect iframe { height: 250px; }
    /* Banner — between sections: 320×50 on mobile, 468×60 on desktop */
    .ad-slot-banner { min-height: 50px; }
    .ad-slot-banner iframe { height: 50px; }
    @media (min-width: 768px) {
      .ad-slot-banner { min-height: 60px; }
      .ad-slot-banner iframe { height: 60px; }
    }
    @media (max-width: 575.98px) {
      .ad-slot-leaderboard { min-height: 50px; }
      .ad-slot-leaderboard iframe { height: 50px; }
    }

    /* ================================================
       CONTENT PAGES  (about, faq, etc.)
    ================================================ */
    .content-page { padding: 56px 0 72px; flex: 1; }
    .content-page h1 {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 800; font-size: clamp(1.8rem, 4vw, 2.8rem);
      line-height: 1.1; letter-spacing: -.025em; color: var(--text);
      margin-bottom: 12px;
    }
    .content-page h1 .grad {
      background: linear-gradient(100deg, var(--em) 0%, #10B981 50%, var(--amb) 100%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .content-page h2 {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700; font-size: 1.35rem; color: var(--text);
      margin: 36px 0 12px;
    }
    .content-page h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700; font-size: 1.05rem; color: var(--text);
      margin: 24px 0 8px;
    }
    .content-page p { color: var(--muted); margin-bottom: 16px; line-height: 1.8; }
    .content-page ul, .content-page ol {
      color: var(--muted); padding-left: 22px; margin-bottom: 16px; line-height: 1.8;
    }
    .content-page li { margin-bottom: 6px; }
    .content-page a { color: var(--em); text-decoration: none; }
    .content-page a:hover { text-decoration: underline; }
    .content-page .lead {
      font-size: 1.05rem; color: var(--muted); line-height: 1.75; margin-bottom: 32px;
    }
    .page-eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 12px; font-weight: 700; letter-spacing: .5px;
      text-transform: uppercase; color: var(--ambDark);
      border: 1px solid var(--borderAmb); padding: 5px 14px;
      border-radius: 999px; margin-bottom: 16px;
      background: var(--ambLight);
    }
    .info-card {
      background: #fff; border: 1px solid var(--border);
      border-radius: var(--r); padding: 24px;
      box-shadow: var(--shadow-sm); margin-bottom: 16px;
    }
    .info-card:hover { border-color: var(--borderHi); box-shadow: var(--shadow-md); }
    .feature-icon {
      width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
      background: var(--emLight); border: 1px solid rgba(5,150,105,.2);
      display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }
    .feature-icon.amb {
      background: var(--ambLight); border-color: rgba(217,119,6,.2);
    }

    /* FAQ accordion */
    .faq-item {
      border: 1px solid var(--border); border-radius: var(--r);
      background: #fff; margin-bottom: 10px; overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .faq-q {
      width: 100%; text-align: left; background: none; border: none; cursor: pointer;
      padding: 18px 22px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 15px;
      color: var(--text);
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      transition: background .15s;
    }
    .faq-q:hover { background: var(--surface); }
    .faq-q .faq-icon {
      width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
      background: var(--emLight); color: var(--em);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700;
      transition: transform .3s, background .2s;
    }
    .faq-item.open .faq-q .faq-icon { transform: rotate(45deg); background: var(--em); color: #fff; }
    .faq-a {
      max-height: 0; overflow: hidden;
      transition: max-height .4s cubic-bezier(.4,0,.2,1), padding .3s;
      padding: 0 22px; color: var(--muted); font-size: 14px; line-height: 1.8;
    }
    .faq-item.open .faq-a { max-height: 400px; padding: 0 22px 18px; }

    /* ================================================
       SITE NAVBAR — Bootstrap collapsible menu
    ================================================ */
    .site-nav {
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 200;
      padding: 0;
    }
    .site-nav .navbar-brand {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 800; font-size: 1.2rem; letter-spacing: -.03em;
      color: var(--text) !important; text-decoration: none;
      display: flex; align-items: center; gap: 10px;
    }
    .site-nav .nav-brand-icon {
      width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--em), var(--emDark));
      display: flex; align-items: center; justify-content: center; font-size: 14px;
      box-shadow: 0 2px 8px var(--emGlow);
    }
    .site-nav .navbar-toggler {
      border: 1px solid var(--border) !important;
      border-radius: var(--rXs) !important; padding: 6px 10px !important;
    }
    .site-nav .navbar-toggler:focus { box-shadow: 0 0 0 3px rgba(5,150,105,.1) !important; }
    .site-nav .navbar-toggler-icon {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%2817%2C24%2C39%2C0.7%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    }
    .site-nav .nav-link {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600; font-size: 13.5px; color: var(--muted) !important;
      padding: 6px 12px !important; border-radius: var(--rXs);
      transition: color .2s, background .2s;
    }
    .site-nav .nav-link:hover, .site-nav .nav-link.active {
      color: var(--em) !important; background: var(--emLight);
    }
    .site-nav .nav-cta {
      background: linear-gradient(135deg, var(--em), var(--emDark));
      color: #fff !important; border-radius: var(--rXs);
      padding: 7px 16px !important; font-size: 13px !important;
      font-weight: 700 !important; white-space: nowrap;
      transition: filter .18s, transform .18s;
    }
    .site-nav .nav-cta:hover { filter: brightness(1.07); transform: translateY(-1px); }

    /* ================================================
       RESPONSIVE TWEAKS
    ================================================ */
    /* xs (< 576px) */
    @media (max-width: 575.98px) {
      .hero              { padding: 44px 0 32px; }
      .hero.hero-compact { padding: 20px 0 16px; }
      .g-card-body       { padding: 16px; }
      .drop-zone         { padding: 28px 12px; }
      .drop-icon-wrap    { width: 52px; height: 52px; font-size: 1.5rem; }
      .stat-pill         { font-size: 12px; padding: 5px 8px; }
      #chatBox           { height: 180px !important; }
      .conn-pill #status { display: none; }
      .content-page      { padding: 36px 0 52px; }
    }

    /* sm (576–767px) */
    @media (min-width: 576px) and (max-width: 767.98px) {
      .hero { padding: 56px 0 40px; }
    }
  </style>

  {% block head %}{% endblock %}

  <style>
    /* ── Auth nav elements ─────────────────────────────────── */
    .nav-login-btn {
      padding: .35rem .9rem !important;
      border: 1.5px solid var(--borderEm);
      border-radius: var(--rSm);
      color: var(--em) !important;
      font-weight: 600 !important;
      font-size: .875rem !important;
      transition: background .2s, color .2s;
    }
    .nav-login-btn:hover {
      background: var(--em) !important;
      color: #fff !important;
    }

    .nav-account-btn {
      display: flex; align-items: center; gap: .5rem;
      padding: .3rem .7rem !important;
      border: 1.5px solid var(--border);
      border-radius: var(--rSm);
      font-size: .875rem !important;
      font-weight: 600 !important;
      color: var(--text) !important;
      transition: border-color .2s, background .2s;
    }
    .nav-account-btn:hover { border-color: var(--borderEm); background: var(--emLight); }
    .nav-account-btn::after { display: none; } /* hide default bs caret */

    .nav-avatar {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: var(--em);
      color: #fff;
      font-size: .75rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .nav-user-menu {
      min-width: 210px;
      border: 1px solid var(--border);
      border-radius: var(--r);
      box-shadow: var(--shadow-md);
      padding: .35rem 0;
    }
    .nav-user-info { padding: .6rem 1rem; }
    .nav-user-name  { font-weight: 600; font-size: .875rem; color: var(--text); }
    .nav-user-email { font-size: .75rem; color: var(--muted2); word-break: break-all; }

    .nav-logout-btn {
      width: 100%; text-align: left;
      background: none; border: none;
      color: var(--rose) !important;
      font-weight: 600;
      cursor: pointer;
    }
    .nav-logout-btn:hover { background: var(--roseLight) !important; }
  </style>


  <!-- Dynamic site config — loads SITE_URL + TURN hosts from server env -->
  <!-- This avoids hardcoding the domain in any client-side JS file -->
  <script>
    window._siteConfig = { siteUrl: '{{ siteUrl }}', turnHosts: [] };
    fetch('/api/site-config')
      .then(r => r.json())
      .then(d => { window._siteConfig = d; })
      .catch(() => {});
  </script>
</head>

<body>

  <div class="bg-canvas"></div>
  <div class="page-wrap">

    {# ================================================
       SITE NAVBAR  — shown on all pages.
       index.njk keeps its own .nav-bar inside {% block content %}
       for the connection pill. All other pages use this.
    ================================================ #}
    {% block navbar %}
    <nav class="site-nav navbar navbar-expand-lg">
      <div class="container-lg">

        <a href="/" class="navbar-brand">
          <span class="nav-brand-icon">&#9889;</span>
          Tran<span style="color:var(--em)">zo</span>
        </a>

        <button class="navbar-toggler" type="button"
          data-bs-toggle="collapse" data-bs-target="#siteNavMenu"
          aria-controls="siteNavMenu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="siteNavMenu">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1 py-2 py-lg-0">
            <li class="nav-item"><a class="nav-link" href="/how-it-works">How It Works</a></li>
            <li class="nav-item"><a class="nav-link" href="/security">Security</a></li>
            <li class="nav-item"><a class="nav-link" href="/faq">FAQ</a></li>
            <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
            <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
              <a class="nav-link nav-cta" href="/">&#9889; Send Files Free</a>
            </li>

            {# ── Auth links — shown based on login state ── #}
            {% if currentUser %}
            <li class="nav-item ms-lg-1 mt-2 mt-lg-0 dropdown">
              <a class="nav-link nav-account-btn dropdown-toggle" href="#"
                 data-bs-toggle="dropdown" aria-expanded="false">
                <span class="nav-avatar">{{ currentUser.name | truncate(1, true, '') | upper }}</span>
                <span class="d-none d-lg-inline">{{ currentUser.name | truncate(14, true, '…') }}</span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end nav-user-menu">
                <li>
                  <div class="nav-user-info">
                    <div class="nav-user-name">{{ currentUser.name }}</div>
                    <div class="nav-user-email">{{ currentUser.email }}</div>
                  </div>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/account/sessions">&#128274; Active Sessions</a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <button class="dropdown-item nav-logout-btn" onclick="doLogout()">
                    &#128682; Log Out
                  </button>
                </li>
              </ul>
            </li>
            {% else %}
            <li class="nav-item ms-lg-1 mt-2 mt-lg-0">
              <a class="nav-link nav-login-btn" href="/auth/login">Sign In</a>
            </li>
            {% endif %}

          </ul>
        </div>

      </div>
    </nav>
    {% endblock %}

    {# ================================================
       TOP AD SLOT — leaderboard (728×90 / 320×50 mobile)
       Replace the src with your actual AdSense ad unit URL.
       AdSense script tag goes in {% block head %} of each page.
    ================================================ #}
    {% block adTop %}{% endblock %}

    {# ================================================
       PAGE CONTENT
    ================================================ #}
    {% block content %}{% endblock %}

    {# ================================================
       BOTTOM AD SLOT — before footer
    ================================================ #}
    {% block adBottom %}{% endblock %}

    {# ================================================
       SITE FOOTER
    ================================================ #}
    {% block footer %}
    <footer class="page-footer pt-5 pb-2">
      <div class="container-lg">
        <div class="row gy-4 pb-4">

          <!-- Brand col -->
          <div class="col-12 col-md-4 col-lg-3">
            <div class="d-flex align-items-center gap-2 mb-3">
              <div class="footer-icon">&#9889;</div>
              <div>
                <div class="footer-name">Tranzo</div>
                <div class="footer-tag">Files never touch our servers.</div>
              </div>
            </div>
            <p style="font-size:13px;color:var(--muted);line-height:1.7;">
              100% free P2P file transfer via WebRTC. No cloud, no signup, no size limits. Works on any device and any browser.
            </p>
          </div>

          <!-- Use cases -->
          <div class="col-6 col-md-2">
            <div class="footer-col-title">Use Cases</div>
            <ul class="footer-col-links">
              <li><a href="/send-large-files">Send Large Files</a></li>
              <li><a href="/android-to-pc-file-transfer">Android to PC</a></li>
              <li><a href="/webrtc-file-transfer">WebRTC Transfer</a></li>
            </ul>
          </div>

          <!-- Learn -->
          <div class="col-6 col-md-2">
            <div class="footer-col-title">Learn</div>
            <ul class="footer-col-links">
              <li><a href="/how-it-works">How It Works</a></li>
              <li><a href="/security">Security</a></li>
              <li><a href="/faq">FAQ</a></li>
              <li><a href="/about">About</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div class="col-6 col-md-2">
            <div class="footer-col-title">Legal</div>
            <ul class="footer-col-links">
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
              <li><a href="/cookies">Cookie Policy</a></li>
              <li><a href="/disclaimer">Disclaimer</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div class="col-6 col-md-2">
            <div class="footer-col-title">Company</div>
            <ul class="footer-col-links">
              <li><a href="/contact">Contact Us</a></li>
            </ul>
            <div style="margin-top:16px;">
              <span class="nav-badge">WebRTC</span>
            </div>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="footer-bottom d-flex flex-wrap align-items-center justify-content-between gap-2">
          <span>&copy; <script>document.write(new Date().getFullYear())</script> Tranzo. All rights reserved.</span>
          <span style="display:flex;gap:16px;flex-wrap:wrap;">
            <a href="/privacy" style="color:var(--muted2);font-size:12px;text-decoration:none;">Privacy</a>
            <a href="/terms"   style="color:var(--muted2);font-size:12px;text-decoration:none;">Terms</a>
            <a href="/cookies" style="color:var(--muted2);font-size:12px;text-decoration:none;">Cookies</a>
          </span>
        </div>

      </div>
    </footer>
    {% endblock %}

  </div><!-- /page-wrap -->

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  {% block scripts %}{% endblock %}

  {# ── doLogout — called by navbar "Log Out" button ── #}
  <script>
  async function doLogout() {
    try {
      const r = await fetch("/auth/logout", { method: "POST" });
      const d = await r.json();
      window.location.href = d.redirect || "/auth/login";
    } catch {
      window.location.href = "/auth/login";
    }
  }
  </script>

</body>
</html>
