{% block content %}
  <section class="hero" id="heroSection">
    <div class="container-lg">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 col-xl-7">

          <div class="hero-eyebrow">&#128274; WebRTC &middot; End-to-End Encrypted</div>

          <h1>Transfer Files <span class="grad">Instantly.</span><br class="d-none d-sm-block">Zero Cloud. Zero Trace.</h1>

          <p class="hero-sub">Your files fly directly between browsers via WebRTC &mdash; no server ever sees them. 100% free, no signup, no limits.</p>

          <div class="trust-badges">
            <span class="trust-badge">&#9889; Direct P2P</span>
            <span class="trust-badge">&#128737; Zero Storage</span>
            <span class="trust-badge">&#128515; Always Free</span>
            <span class="trust-badge">&#128241; Any Device</span>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ================================================
       APP
  ================================================ -->
  <main class="flex-grow-1">
    <div class="container-lg">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 col-xl-7 pb-5">

          <!-- CONNECTION CARD — always visible -->
          <div class="g-card strip-em">
            <div class="g-card-body">
              <div class="section-label">Connect to a Room</div>

              <div class="row g-3 align-items-end">
                <!-- Device name -->
                <div class="col-12 col-sm-6 col-md-5">
                  <label class="field-label" for="deviceName">Your Name</label>
                  <input class="g-input" type="text" id="deviceName"
                    placeholder="e.g. Laptop Chrome" autocomplete="off" />
                </div>
                <!-- Room ID -->
                <div class="col-12 col-sm-6 col-md-4">
                  <label class="field-label" for="roomId">Room ID</label>
                  <input class="g-input" type="text" id="roomId"
                    placeholder="e.g. forest-42" autocomplete="off" />
                </div>
                <!-- Buttons: always side by side -->
                <div class="col-12 col-md-3">
                  <div class="d-flex gap-2">
                    <button class="btn-ghost w-100" id="createBtn">Create</button>
                    <button class="btn-em w-100"    id="joinBtn">Join &rarr;</button>
                  </div>
                  <!-- Live camera QR scanner -->
                  <div style="margin-top:8px;text-align:center;">
                    <button onclick="openQrScanner()" style="background:none;border:none;padding:0;font-size:12px;color:var(--em);font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;">
                      <span>&#128247;</span><span>Scan QR to join</span>
                    </button>
                  </div>
                </div>
              </div>

              <div id="roomHint"></div>
            </div>
          </div>

          <!-- ROOM MEMBERS PANEL — controlled by multiroom.js -->
          <div class="reveal-panel" id="membersPanel">
            <div class="g-card" id="roomMembersCard">
              <div class="g-card-body">
                <div class="section-label">&#128101; Room Members</div>
                <div id="membersList"></div>
              </div>
            </div>
          </div>

          <!-- FILE ACCEPT SCOREBOARD — controlled by multiroom.js -->
          <div class="reveal-panel" id="scorePanel">
            <div class="g-card" id="fileScoreCard">
              <div class="g-card-body">
                <div class="section-label">&#128202; Transfer Status</div>
                <div id="fileScoreList"></div>
              </div>
            </div>
          </div>

          <!-- SHARE LINK PANEL -->
          <div class="reveal-panel" id="shareLinkPanel">
            <div class="g-card" id="shareLinkCard">
              <div class="g-card-body">

                <div class="d-flex align-items-start align-items-sm-center gap-3 mb-3">
                  <div class="link-icon-wrap">&#128279;</div>
                  <div>
                    <div class="link-title">Invite via Link</div>
                    <div class="link-sub">Share this link &mdash; anyone who opens it joins your room instantly</div>
                  </div>
                </div>

                <!-- Input + copy button: always inline, wraps gracefully -->
                <div class="d-flex align-items-stretch">
                  <input type="text" id="shareLinkInput" readonly placeholder="Generating link&hellip;" />
                  <button class="btn-em btn-sm-custom copy-attached flex-shrink-0" id="copyLinkBtn">&#128203; Copy</button>
                </div>

                <!-- QR code — shown automatically, with share + download actions -->
                <div id="qrSection" style="margin-top:14px;">
                  <!-- QR canvas renders here -->
                  <div id="qrWrap" style="display:none;">
                    <div style="display:flex;gap:12px;align-items:flex-start;flex-wrap:wrap;">
                      <!-- QR image -->
                      <div id="qrCanvas" style="display:inline-block;border-radius:12px;border:1px solid var(--border);padding:10px;background:#fff;flex-shrink:0;"></div>
                      <!-- Action buttons stacked beside QR -->
                      <div style="display:flex;flex-direction:column;gap:8px;justify-content:center;min-width:120px;">
                        <button id="qrDownloadBtn" onclick="downloadQr()" class="btn-ghost btn-sm-custom" style="font-size:12px;display:flex;align-items:center;gap:6px;">
                          &#11015; Save QR
                        </button>
                        <button id="qrShareBtn" onclick="shareQr()" class="btn-em btn-sm-custom" style="font-size:12px;display:flex;align-items:center;gap:6px;">
                          &#8599; Share
                        </button>
                        <button id="qrWhatsappBtn" onclick="shareWhatsapp()" style="background:#25D366;color:#fff;border:none;border-radius:var(--rXs);font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:12px;padding:8px 14px;cursor:pointer;display:flex;align-items:center;gap:6px;">
                          &#128172; WhatsApp
                        </button>
                      </div>
                    </div>
                    <p style="font-size:12px;color:var(--muted);margin-top:8px;margin-bottom:0;">&#128241; Point phone camera at this code to join instantly</p>
                  </div>
                </div>

                <div id="shareLinkHint" class="mt-2"
                  style="font-size:13px;color:var(--success);font-weight:600;display:none;">
                  &#10003; Copied to clipboard!
                </div>
                <p class="mt-2 mb-0" style="font-size:13px;color:var(--muted);">&#8987; Expires when you leave the room</p>

              </div>
            </div>
          </div>

          <!-- CHAT PANEL -->
          <div class="reveal-panel" id="chatPanel">
            <div class="g-card" id="chatSection">
              <div class="g-card-body">
                <div class="section-label">Live Chat</div>
                <div id="chatBox"></div>
                <!-- Input row: input grows, button stays right -->
                <div class="d-flex gap-2 mt-3">
                  <input class="g-input flex-grow-1" type="text" id="messageInput"
                    placeholder="Say something&hellip;" />
                  <button class="btn-amb btn-sm-custom flex-shrink-0" id="sendBtn">Send &#8593;</button>
                </div>
              </div>
            </div>
          </div>

          <!-- FILE TRANSFER PANEL -->
          <div class="reveal-panel" id="filePanel">
            <div class="g-card" style="border:none;background:transparent;box-shadow:none;">
              <div class="g-card-body" id="tui-card-body" style="padding:0;">
                <!--
                  ALL IDs that script.js reads at parse time live here as static HTML.
                  transfer-ui.js replaces the visual content but keeps these IDs in DOM.
                  Never remove: fileInput, fileStatus, progressBar, progressText,
                  speedText, etaText, pauseBtn, resumeBtn, cancelBtn, progressFill.
                -->

                <!-- Hidden static elements for script.js — DO NOT REMOVE -->
                <div style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);pointer-events:none;" aria-hidden="true">
                  <input  type="file" id="fileInput" multiple tabindex="-1" />
                  <span   id="fileStatus"></span>
                  <progress id="progressBar" value="0" max="100"></progress>
                  <span   id="progressText">0%</span>
                  <span   id="speedText">Speed: 0 MB/s</span>
                  <span   id="etaText">Remaining: --</span>
                  <div    id="progressFill"></div>
                  <button id="pauseBtn"  disabled>Pause</button>
                  <button id="resumeBtn" disabled>Resume</button>
                  <button id="cancelBtn" disabled>Cancel</button>
                </div>

                <!-- transfer-ui.js mounts the dial UI here -->
                <div id="tui-mount-target"></div>

              </div>
            </div>
            <!-- filePanelQueues: outside the card as script.js expects -->
            <div id="filePanelQueues" style="display:none;"></div>
          </div>
          <!-- /filePanel -->

        </div><!-- /col -->
      </div><!-- /row -->
    </div><!-- /container -->
  </main>
{% endblock %}

