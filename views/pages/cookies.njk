{% extends "../layouts/base.njk" %}

{% block title %}Cookie Policy – Tranzo{% endblock %}
{% block metaDesc %}How Tranzo uses cookies and local storage. We use minimal cookies — only what's needed for the service and advertising to keep Tranzo free.{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ siteUrl }}/cookies" />{% endblock %}
{% block ogUrl %}{{ siteUrl }}/cookies{% endblock %}

{% block content %}
<main class="content-page">
  <div class="container-lg">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-7">
        <div class="page-eyebrow">&#127850; Legal</div>
        <h1>Cookie <span class="grad">Policy</span></h1>
        <p class="lead">Last updated: <strong>January 2025</strong></p>
        <p>This policy explains how Tranzo uses cookies and similar technologies on <strong>{{ siteUrl | replace("https://", "") }}</strong>.</p>

        <h2>What Are Cookies?</h2>
        <p>Cookies are small text files stored in your browser when you visit a website. They help websites remember your preferences and track usage patterns.</p>

        <h2>Cookies We Use</h2>

        <div class="g-card mb-3">
          <div class="g-card-body">
            <h3 style="margin-top:0;">&#9989; Strictly Necessary</h3>
            <p class="mb-0">Tranzo uses <strong>sessionStorage</strong> (not a cookie) to remember room auto-accept preferences within a single browser session. This data is cleared when you close the tab and never leaves your device. No consent is required for this.</p>
          </div>
        </div>

        <div class="g-card mb-3">
          <div class="g-card-body">
            <h3 style="margin-top:0;">&#128250; Advertising Cookies</h3>
            <p>To keep Tranzo free, we display advertisements. Our ad partners (including Google AdSense) may set cookies to:</p>
            <ul class="mb-0">
              <li>Measure ad performance and impressions</li>
              <li>Limit how often you see the same ad</li>
              <li>Personalise ads based on your interests (if you consent)</li>
            </ul>
          </div>
        </div>

        <div class="g-card mb-4">
          <div class="g-card-body">
            <h3 style="margin-top:0;">&#128202; Analytics Cookies</h3>
            <p class="mb-0">We may use anonymised analytics to understand page visit volumes. No personally identifiable information is collected.</p>
          </div>
        </div>

        <h2>Third-Party Cookies</h2>
        <p>Tranzo loads resources from the following third-party domains, which may set their own cookies:</p>
        <ul>
          <li><strong>fonts.googleapis.com</strong> — Google Fonts</li>
          <li><strong>cdn.jsdelivr.net</strong> — Bootstrap and QR libraries</li>
          <li><strong>googlesyndication.com / doubleclick.net</strong> — Google AdSense advertising</li>
        </ul>
        <p>We do not control these third-party cookies. Please refer to each provider's privacy policy for more information.</p>

        <h2>Managing Cookies</h2>
        <p>You can control cookies through your browser settings:</p>
        <ul>
          <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener">Chrome cookie settings</a></li>
          <li><a href="https://support.mozilla.org/en-US/kb/cookies-information-websites-store-on-your-computer" target="_blank" rel="noopener">Firefox cookie settings</a></li>
          <li><a href="https://support.apple.com/guide/safari/manage-cookies-sfri11471/mac" target="_blank" rel="noopener">Safari cookie settings</a></li>
        </ul>
        <p>You can also opt out of Google personalised ads at <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener">Google Ads Settings</a>.</p>

        <h2>Contact</h2>
        <p>Cookie questions? <a href="/contact">Contact us</a>.</p>
      </div>
    </div>
  </div>
</main>
{% endblock %}
