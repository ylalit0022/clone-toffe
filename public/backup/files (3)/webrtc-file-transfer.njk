{% block canonical %}<link rel="canonical" href="https://share.rumnnlg.com/webrtc-file-transfer" />{% endblock %}
{% block ogTitle %}WebRTC File Transfer – Browser-to-Browser | Tranzo{% endblock %}
{% block ogUrl %}https://share.rumnnlg.com/webrtc-file-transfer{% endblock %}

{% block adTop %}
<div class="container-lg pt-3">
  <div class="ad-slot ad-slot-leaderboard">
    <iframe src="about:blank" title="Advertisement" aria-label="Advertisement" scrolling="no"></iframe>
  </div>
