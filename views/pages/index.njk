<!-- QR: creator-side render + share + download + receiver live scanner -->
<script>
// ─── State ────────────────────────────────────────────────────────────────────
var _qrInstance   = null;
var _qrCurrentUrl = '';
var _scanStream   = null;
var _scanRaf      = null;
var _scanCanvas   = document.createElement('canvas');
var _scanCtx      = _scanCanvas.getContext('2d');

// ─── CREATOR: render QR automatically when share link is set ─────────────────
window.__onShareLinkSet = function(url) {
  _qrCurrentUrl = url;
  var wrap = document.getElementById('qrWrap');
  var div  = document.getElementById('qrCanvas');
  if (!wrap || !div) return;
  // Clear old instance
  div.innerHTML = '';
  _qrInstance = null;

  function doRender() {
    if (typeof QRCode === 'undefined') { setTimeout(doRender, 200); return; }
    try {
      _qrInstance = new QRCode(div, {
        text:         url,
        width:        180,
        height:       180,
        colorDark:    '#111827',
        colorLight:   '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
      wrap.style.display = 'block';
    } catch(e) { console.warn('[QR] render error:', e); }
  }
  doRender();
};

// Get the rendered QR as a PNG data-URL
function _getQrDataUrl() {
  var div = document.getElementById('qrCanvas');
  if (!div) return null;
  var img    = div.querySelector('img');
  var canvas = div.querySelector('canvas');
  if (canvas) return canvas.toDataURL('image/png');
  if (img && img.src) return img.src;
  return null;
}

// ─── DOWNLOAD QR ─────────────────────────────────────────────────────────────
function downloadQr() {
  var data = _getQrDataUrl();
  if (!data) { console.warn('[QR] nothing to download yet'); return; }
  var a = document.createElement('a');
  a.href     = data;
  a.download = 'tranzo-room-qr.png';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
}

// ─── SHARE QR (Web Share API — WhatsApp, FB, Instagram, etc.) ────────────────
function shareQr() {
  var url  = _qrCurrentUrl;
  var data = _getQrDataUrl();
  if (!url) return;

  // Try Web Share API with file (image) — supported on Android Chrome / iOS Safari
  if (navigator.share && data) {
    fetch(data)
      .then(function(r) { return r.blob(); })
      .then(function(blob) {
        var file = new File([blob], 'tranzo-room-qr.png', { type: 'image/png' });
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          return navigator.share({
            title: 'Join my Tranzo room',
            text:  'Scan this QR or tap the link to join my file transfer room',
            url:   url,
            files: [file]
          });
        } else {
          // Share URL only (no file)
          return navigator.share({ title: 'Join my Tranzo room', text: 'Tap to join my file transfer room', url: url });
        }
      })
      .catch(function(e) { if (e.name !== 'AbortError') console.warn('[QR] share error:', e); });
    return;
  }

  // Fallback: share URL only
  if (navigator.share) {
    navigator.share({ title: 'Join my Tranzo room', url: url }).catch(function() {});
    return;
  }

  // Last resort: copy to clipboard
  navigator.clipboard.writeText(url).then(function() {
    var btn = document.getElementById('qrShareBtn');
    if (btn) { btn.innerHTML = '&#10003; Link copied!'; setTimeout(function() { btn.innerHTML = '&#8599; Share'; }, 2000); }
  }).catch(function() {});
}

// ─── WHATSAPP SHARE ──────────────────────────────────────────────────────────
function shareWhatsapp() {
  var url = _qrCurrentUrl;
  if (!url) return;
  var text = encodeURIComponent('Join my Tranzo file transfer room: ' + url);
  window.open('https://api.whatsapp.com/send?text=' + text, '_blank');
}

// ─── RECEIVER: live camera QR scanner ────────────────────────────────────────
function openQrScanner() {
  var modal = document.getElementById('qrScanModal');
  if (!modal) return;
  modal.style.display = 'flex';
  _startCamera();
}

function closeQrScanner() {
  _stopCamera();
  var modal = document.getElementById('qrScanModal');
  if (modal) modal.style.display = 'none';
  _setScanStatus('Scanning\u2026', false);
}

function _startCamera() {
  var video  = document.getElementById('qrVideo');
  var status = document.getElementById('qrScanStatus');
  if (!video) return;

  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    _setScanStatus('Camera not available on this browser', true);
    return;
  }

  navigator.mediaDevices.getUserMedia({
    video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } }
  }).then(function(stream) {
    _scanStream = stream;
    video.srcObject = stream;
    video.play();
    video.addEventListener('loadedmetadata', function() {
      _scanCanvas.width  = video.videoWidth  || 640;
      _scanCanvas.height = video.videoHeight || 640;
      _scanFrame();
    }, { once: true });
  }).catch(function(err) {
    console.warn('[QR Scanner]', err);
    var msg = err.name === 'NotAllowedError'
      ? 'Camera permission denied. Upload an image instead.'
      : 'Camera unavailable. Upload an image instead.';
    _setScanStatus(msg, true);
  });
}

function _stopCamera() {
  if (_scanRaf) { cancelAnimationFrame(_scanRaf); _scanRaf = null; }
  if (_scanStream) {
    _scanStream.getTracks().forEach(function(t) { t.stop(); });
    _scanStream = null;
  }
  var video = document.getElementById('qrVideo');
  if (video) { video.srcObject = null; }
}

function _scanFrame() {
  var video = document.getElementById('qrVideo');
  if (!video || !_scanStream) return;

  if (video.readyState === video.HAVE_ENOUGH_DATA) {
    _scanCtx.drawImage(video, 0, 0, _scanCanvas.width, _scanCanvas.height);
    var imageData = _scanCtx.getImageData(0, 0, _scanCanvas.width, _scanCanvas.height);

    // jsQR may not be loaded yet — wait for it
    if (typeof jsQR !== 'undefined') {
      var code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'dontInvert' });
      if (code && code.data) {
        _onQrDetected(code.data);
        return;   // stop scanning
      }
    }
  }
  _scanRaf = requestAnimationFrame(_scanFrame);
}

function _onQrDetected(data) {
  // Visual feedback
  var frame = document.getElementById('qrScanFrame');
  if (frame) {
    frame.style.transition = 'outline .2s';
    frame.style.outline = '3px solid var(--em)';
  }
  _setScanStatus('&#10003; QR detected — joining room…', false);

  // Extract room param
  var room = data;
  try {
    var u = new URL(data);
    var r = u.searchParams.get('room');
    if (r) room = r;
  } catch {}

  // Stop camera and close modal after short success delay
  setTimeout(function() {
    _stopCamera();
    var modal = document.getElementById('qrScanModal');
    if (modal) modal.style.display = 'none';

    // Fill room input and join
    var roomInput = document.getElementById('roomId');
    if (roomInput) {
      roomInput.value = room;
      roomInput.dispatchEvent(new Event('input'));
    }

    // If mode=download was in the URL, set auto-accept
    try {
      var u2 = new URL(data);
      if (u2.searchParams.get('mode') === 'download') {
        try { sessionStorage.setItem('autoAccept:' + room, '1'); } catch {}
      }
    } catch {}

    var joinBtn = document.getElementById('joinBtn');
    if (joinBtn) joinBtn.click();

    _setScanStatus('Scanning\u2026', false);
    if (frame) { frame.style.outline = ''; }
  }, 600);
}

function _setScanStatus(msg, isError) {
  var el = document.getElementById('qrScanStatus');
  if (!el) return;
  el.innerHTML = msg;
  el.style.color = isError ? '#FCA5A5' : '#fff';
}

// ─── FALLBACK: upload image ──────────────────────────────────────────────────
function handleQrImageUpload(input) {
  var file = input && input.files && input.files[0];
  if (!file) return;

  var reader = new FileReader();
  reader.onload = function(e) {
    var img = new Image();
    img.onload = function() {
      var c = document.createElement('canvas');
      c.width = img.width; c.height = img.height;
      var ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0);
      var imageData = ctx.getImageData(0, 0, c.width, c.height);

      if (typeof jsQR === 'undefined') {
        _setScanStatus('Scanner loading, please wait…', false);
        setTimeout(function() { handleQrImageUpload(input); }, 400);
        return;
      }

      var code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'dontInvert' });
      if (!code) {
        _setScanStatus('&#10060; No QR found in image — try another', true);
        setTimeout(function() { _setScanStatus('Scanning\u2026', false); }, 2500);
        input.value = '';
        return;
      }
      input.value = '';
      _onQrDetected(code.data);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}
</script>

<!-- fflate: fast in-browser ZIP (sender compress + receiver extract) -->
<script src="https://cdn.jsdelivr.net/npm/fflate@0.8.2/umd/index.js"></script>
<script src="multiroom.js"></script>
<script src="transfer-alerts.js"></script>
<script src="transfer-ui.js"></script>
<script src="script.js"></script>
<script src="enhancements.js"></script>
{% endblock %}
