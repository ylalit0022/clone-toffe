{% extends "layouts/base.njk" %}

{% block title %}{{ metaTitle }} | Tranzo Blog{% endblock %}
{% block metaDesc %}{{ metaDescription }}{% endblock %}

{% block canonical %}
  <link rel="canonical" href="{{ canonicalUrl }}" />
  {% if noIndex %}<meta name="robots" content="noindex, follow" />{% endif %}
{% endblock %}

{% block head %}
  <meta property="og:type"        content="article" />
  <meta property="og:site_name"   content="Tranzo" />
  <meta property="og:title"       content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:url"         content="{{ canonicalUrl }}" />
  {% if ogImage %}<meta property="og:image" content="{{ ogImage }}" />{% endif %}
  {% if post.publishedDate %}<meta property="article:published_time" content="{{ post.publishedDate }}" />{% endif %}
  {% if post.category %}    <meta property="article:section"        content="{{ post.category }}" />{% endif %}
  {% if post.author %}      <meta property="article:author"         content="{{ post.author.name }}" />{% endif %}
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="{{ post.twitterTitle or ogTitle }}" />
  <meta name="twitter:description" content="{{ ogDescription }}" />
  {% if post.twitterImage %}<meta name="twitter:image" content="{{ post.twitterImage }}" />{% endif %}
  {{ schemaScripts | safe }}

  <style>
/* ═══════════════════════════════════════════════════════════════
   BLOG POST  —  3-column desktop layout
   Desktop (>1024px):  [TOC-left 240px] [content 680px] [author-right 240px]
   Tablet  (768-1024): [TOC-left 200px] [content 1fr]   [author hidden → bottom]
   Mobile  (<768px):   single column, TOC accordion before first h2
═══════════════════════════════════════════════════════════════ */

:root {
  --post-max:   1220px;
  --col-toc:    240px;
  --col-author: 240px;
  --col-gap:    40px;
  --toc-bg:     #f8fafb;
  --toc-border: #e5e7eb;
  --toc-active: var(--em, #059669);
  --fs-body:    17px;
  --lh-body:    1.85;
  --font-head:  'Bricolage Grotesque', sans-serif;
  --font-body:  'Plus Jakarta Sans', sans-serif;
  --font-mono:  'Courier New', Consolas, monospace;
}

/* ── Breadcrumbs ────────────────────────────────────────────── */
.bc-wrap  { max-width: var(--post-max); margin: 0 auto; padding: 14px 24px 0; }
.bc-list  { display:flex; align-items:center; flex-wrap:wrap; list-style:none; padding:0; margin:0; font-size:12px; color:var(--muted2); }
.bc-item  { display:flex; align-items:center; }
.bc-link  { color:var(--muted); text-decoration:none; } .bc-link:hover { color:var(--em); }
.bc-sep   { margin:0 7px; opacity:.35; }
.bc-current { color:var(--muted2); }

/* ── Hero ───────────────────────────────────────────────────── */
.post-hero {
  background: linear-gradient(160deg, #059669 0%, #047857 100%);
  padding: clamp(40px,6vw,80px) 24px clamp(32px,5vw,60px);
  text-align: center; color: #fff;
}
.post-hero-inner { max-width: 820px; margin: 0 auto; }
.post-cat-pill {
  display: inline-block; background: rgba(255,255,255,.18); color: #fff;
  font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  padding: 5px 14px; border-radius: 999px; text-decoration: none; margin-bottom: 18px;
  border: 1px solid rgba(255,255,255,.3); transition: background .2s;
}
.post-cat-pill:hover { background: rgba(255,255,255,.28); color: #fff; }
.post-hero h1 {
  font-family: var(--font-head);
  font-size: clamp(26px, 4vw, 42px); font-weight: 800;
  line-height: 1.18; letter-spacing: -.03em; color: #fff; margin: 0 0 20px;
}
.post-meta-row {
  display: flex; align-items: center; justify-content: center;
  gap: 14px; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,.85);
}
.post-meta-author-link {
  display: flex; align-items: center; gap: 8px;
  color: #fff; text-decoration: none; font-weight: 600;
}
.post-meta-author-link:hover { color: rgba(255,255,255,.8); }
.post-meta-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  object-fit: cover; border: 2px solid rgba(255,255,255,.5);
}
.post-meta-avatar-init {
  width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,.2);
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 13px; flex-shrink: 0;
}
.post-meta-sep { opacity: .4; }

/* ── Cover image ────────────────────────────────────────────── */
.post-cover-section { max-width: var(--post-max); margin: 0 auto; padding: 32px 24px 0; }
.post-cover { width:100%; max-height:480px; object-fit:cover; border-radius:var(--r); box-shadow:var(--shadow-lg); display:block; }

/* ══════════════════════════════════════════════════════════════
   3-COLUMN GRID
   Areas:  toc | content | author
   Desktop: fixed-width TOC left, content center, author right
══════════════════════════════════════════════════════════════ */
.post-page {
  max-width: var(--post-max);
  margin: 0 auto;
  padding: 44px 24px 80px;
  display: grid;
  grid-template-columns: var(--col-toc) 1fr var(--col-author);
  grid-template-areas: "toc content author";
  gap: 0 var(--col-gap);
  align-items: start;
}

/* LEFT: TOC column */
.post-toc-col {
  grid-area: toc;
  position: sticky;
  top: 88px;
  min-width: 0;
}

/* CENTER: Article content */
.post-content-col {
  grid-area: content;
  min-width: 0;
}

/* RIGHT: Author column */
.post-author-col {
  grid-area: author;
  position: sticky;
  top: 88px;
  min-width: 0;
}

/* ── Desktop LEFT TOC ───────────────────────────────────────── */
.toc-desktop {
  background: var(--toc-bg);
  border: 1px solid var(--toc-border);
  border-radius: var(--r);
  overflow: hidden;
}
.toc-desktop-header {
  padding: 13px 16px 11px;
  border-bottom: 1px solid var(--toc-border);
  background: #fff;
}
.toc-desktop-title {
  font-family: var(--font-head);
  font-size: 11px; font-weight: 700;
  letter-spacing: .8px; text-transform: uppercase;
  color: #6b7280;
}
.toc-desktop-body {
  padding: 8px 0 10px;
  max-height: 70vh;
  overflow-y: auto;
  scrollbar-width: thin;
}
.toc-desktop ol, .toc-desktop ul { list-style: none; padding: 0; margin: 0; }
.toc-desktop li { padding: 0; }
.toc-desktop a {
  display: block; padding: 5px 16px;
  font-size: 12.5px; color: #4b5563; text-decoration: none;
  line-height: 1.45; border-left: 2px solid transparent;
  transition: all .15s;
}
.toc-desktop a:hover { color: var(--toc-active); background: rgba(5,150,105,.05); }
.toc-desktop a.toc-active {
  color: var(--toc-active); border-left-color: var(--toc-active);
  background: rgba(5,150,105,.07); font-weight: 600;
}
.toc-desktop li[data-level="3"] a { padding-left: 28px; font-size: 11.5px; color: #9ca3af; }
.toc-desktop li[data-level="3"] a.toc-active { color: var(--toc-active); }

/* ── RIGHT sidebar author card ──────────────────────────────── */
.sidebar-author {
  background: #fff; border: 1px solid var(--toc-border);
  border-radius: var(--r); padding: 20px; text-align: center;
}
.sidebar-author-avatar {
  width: 72px; height: 72px; border-radius: 50%; object-fit: cover;
  border: 3px solid var(--borderEm); margin: 0 auto 12px; display: block;
}
.sidebar-author-avatar-init {
  width: 72px; height: 72px; border-radius: 50%;
  background: var(--emLight); color: var(--emDark);
  font-size: 26px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12px;
}
.sidebar-author-name {
  font-family: var(--font-head); font-size: 15px; font-weight: 800; margin-bottom: 3px;
}
.sidebar-author-name a { color: #111827; text-decoration: none; }
.sidebar-author-name a:hover { color: var(--em); }
.sidebar-author-role {
  font-size: 10px; font-weight: 700; letter-spacing: .7px;
  text-transform: uppercase; color: var(--emDark); margin-bottom: 10px;
}
.sidebar-author-bio { font-size: 12.5px; color: var(--muted); line-height: 1.6; margin-bottom: 12px; text-align: left; }
.sidebar-author-links { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; }
.sidebar-author-link {
  display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600;
  color: var(--muted); text-decoration: none; padding: 4px 9px;
  border-radius: var(--rXs); border: 1px solid var(--border); transition: all .18s;
}
.sidebar-author-link:hover { color: var(--em); border-color: var(--em); }
.sidebar-author-more {
  display: block; margin-top: 10px; font-size: 11px; font-weight: 700;
  color: var(--em); text-decoration: none; text-align: center;
}
.sidebar-author-more:hover { text-decoration: underline; }

/* ── MOBILE TOC (accordion, shows before content on small screens) ── */
.toc-mobile {
  display: none;
  margin: 0 0 2em;
  background: var(--toc-bg);
  border: 1px solid var(--toc-border);
  border-radius: var(--r);
  overflow: hidden;
}
.toc-mobile-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 13px 16px; background: #fff; border-bottom: 1px solid var(--toc-border);
  cursor: pointer; user-select: none;
}
.toc-mobile-title { font-family: var(--font-head); font-size: 14px; font-weight: 700; color: #111827; }
.toc-mobile-arrow { font-size: 16px; color: var(--muted2); transition: transform .25s; line-height: 1; }
.toc-mobile-arrow.open { transform: rotate(180deg); }
.toc-mobile-body { display: none; padding: 6px 0 10px; }
.toc-mobile-body.open { display: block; }
.toc-mobile ol, .toc-mobile ul { list-style: none; padding: 0; margin: 0; }
.toc-mobile a {
  display: block; padding: 7px 16px; font-size: 13.5px; color: #374151;
  text-decoration: none; line-height: 1.45; transition: color .15s, background .15s;
}
.toc-mobile a:hover { color: var(--em); background: rgba(5,150,105,.05); }
.toc-mobile li[data-level="3"] a { padding-left: 30px; font-size: 13px; color: var(--muted); }

/* ── Article body typography ────────────────────────────────── */
.post-body {
  font-family: var(--font-body); font-size: var(--fs-body);
  line-height: var(--lh-body); color: #1a1a2e;
}
.post-body h1,.post-body h2,.post-body h3,.post-body h4,.post-body h5,.post-body h6 {
  font-family: var(--font-head); color: #111827; scroll-margin-top: 96px;
}
.post-body h1 { font-size: clamp(26px,4vw,38px); font-weight:800; line-height:1.18; letter-spacing:-.025em; margin:2.2em 0 .7em; }
.post-body h2 { font-size: clamp(20px,3vw,28px); font-weight:800; line-height:1.22; letter-spacing:-.02em; margin:2em 0 .65em; padding-top:.1em; }
.post-body h3 { font-size: clamp(17px,2.5vw,21px); font-weight:700; line-height:1.3; margin:1.8em 0 .55em; }
.post-body h4 { font-size:17px; font-weight:700; margin:1.5em 0 .5em; }
.post-body h5,.post-body h6 { font-size:15px; font-weight:700; margin:1.3em 0 .45em; }
.post-body p  { margin-bottom:1.45em; }
.post-body ul,.post-body ol { padding-left:1.6em; margin-bottom:1.45em; }
.post-body li { margin-bottom:.45em; line-height:1.75; }
.post-body li > ul,.post-body li > ol { margin-top:.35em; margin-bottom:.35em; }
.post-body blockquote {
  border-left: 4px solid var(--em); margin: 2em 0; padding: 1em 1.4em;
  background: #f0fdf4; border-radius: 0 var(--rSm) var(--rSm) 0;
  font-style: italic; color: #374151; font-size: 1.04em;
}
.post-body blockquote p:last-child { margin-bottom: 0; }
.post-body code {
  background: #f3f4f6; color: #e11d48; padding: 2px 7px;
  border-radius: 5px; font-size: .88em; font-family: var(--font-mono);
}
.post-body pre {
  background: #0f172a; color: #e2e8f0; padding: 20px 24px;
  border-radius: var(--r); overflow-x: auto; margin: 1.8em 0;
  font-size: 13.5px; line-height: 1.7; box-shadow: var(--shadow-md);
}
.post-body pre code { background:none; color:inherit; padding:0; }
.post-body a { color:var(--em); text-decoration:underline; text-underline-offset:3px; text-decoration-thickness:1px; }
.post-body a:hover { color:var(--emDark); text-decoration-thickness:2px; }
.post-body img { max-width:100%; height:auto; border-radius:var(--rSm); margin:1.5em 0; display:block; box-shadow:var(--shadow-sm); }
.post-body figure { margin:1.8em 0; }
.post-body figcaption { font-size:13px; color:var(--muted2); text-align:center; margin-top:8px; }
.post-body table { width:100%; border-collapse:collapse; margin:1.8em 0; font-size:15px; box-shadow:var(--shadow-sm); border-radius:var(--rSm); overflow:hidden; }
.post-body th { background:var(--em); color:#fff; font-weight:700; padding:11px 15px; text-align:left; font-size:13px; }
.post-body td { padding:10px 15px; border-bottom:1px solid #f3f4f6; color:#374151; }
.post-body tr:nth-child(even) td { background:#f9fafb; }
.post-body tr:last-child td { border-bottom:none; }
.post-body hr { border:none; border-top:2px solid #f3f4f6; margin:2.5em 0; }

/* ── Bottom author card (E-E-A-T, full-width under content) ─── */
.author-card-bottom {
  margin-top: 52px; padding: 24px 26px;
  background: #f8fafb; border: 1px solid var(--toc-border); border-radius: var(--r);
  display: flex; gap: 18px; align-items: flex-start;
}
.author-card-bottom-avatar {
  width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
  flex-shrink: 0; border: 3px solid var(--borderEm);
}
.author-card-bottom-avatar-init {
  width: 80px; height: 80px; border-radius: 50%; flex-shrink: 0;
  background: var(--emLight); color: var(--emDark);
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 28px; border: 3px solid var(--borderEm);
}
.author-card-bottom-meta { flex: 1; min-width: 0; }
.author-card-bottom-top {
  display: flex; justify-content: space-between;
  align-items: flex-start; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;
}
.author-card-bottom-name { font-family:var(--font-head); font-weight:800; font-size:17px; }
.author-card-bottom-name a { color:#111827; text-decoration:none; }
.author-card-bottom-name a:hover { color:var(--em); }
.author-card-bottom-role { font-size:11px; font-weight:700; letter-spacing:.7px; text-transform:uppercase; color:var(--emDark); margin-top:2px; }
.author-card-bottom-bio { font-size:13.5px; color:var(--muted); line-height:1.65; margin-bottom:10px; }
.author-card-bottom-links { display:flex; gap:10px; flex-wrap:wrap; }
.author-card-bottom-link {
  display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:600;
  color:var(--muted); text-decoration:none; border:1px solid var(--border);
  padding:5px 10px; border-radius:var(--rXs); transition:all .18s;
}
.author-card-bottom-link:hover { color:var(--em); border-color:var(--em); }
.author-card-bottom-more { font-size:12px; font-weight:700; color:var(--em); text-decoration:none; display:inline-block; margin-top:8px; }
.author-card-bottom-more:hover { text-decoration:underline; }

/* ── Tags ───────────────────────────────────────────────────── */
.post-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:36px; padding-top:28px; border-top:1px solid #f3f4f6; }
.post-tag {
  display:inline-block; padding:4px 12px; font-size:12px; font-weight:600;
  background:#f3f4f6; color:#374151; border-radius:999px; text-decoration:none;
  border:1px solid #e5e7eb; transition:all .18s;
}
.post-tag:hover { background:var(--emLight); color:var(--emDark); border-color:var(--borderEm); }

/* ── Related posts ──────────────────────────────────────────── */
.related-section { max-width:var(--post-max); margin:0 auto; padding:0 24px 72px; }
.related-heading {
  font-family:var(--font-head); font-size:clamp(22px,3vw,30px);
  font-weight:800; text-align:center; color:#111827; margin-bottom:36px;
}
.related-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:24px; }
.rp-card {
  display:flex; flex-direction:column; background:#fff;
  border:1px solid var(--toc-border); border-radius:var(--r);
  overflow:hidden; text-decoration:none; color:inherit; transition:box-shadow .2s,transform .2s;
}
.rp-card:hover { box-shadow:var(--shadow-md); transform:translateY(-3px); color:inherit; text-decoration:none; }
.rp-card-img { width:100%; height:185px; object-fit:cover; display:block; transition:transform .35s; }
.rp-card:hover .rp-card-img { transform:scale(1.03); }
.rp-card-img-placeholder {
  width:100%; height:185px;
  background:linear-gradient(135deg,var(--emLight),#dbeafe);
  display:flex; align-items:center; justify-content:center;
}
.rp-card-body { padding:18px 20px 20px; flex:1; display:flex; flex-direction:column; }
.rp-card-cat { font-size:11px; font-weight:700; letter-spacing:.7px; text-transform:uppercase; color:var(--emDark); margin-bottom:8px; }
.rp-card-title { font-family:var(--font-head); font-size:16px; font-weight:700; line-height:1.35; color:#111827; margin-bottom:9px; }
.rp-card:hover .rp-card-title { color:var(--em); }
.rp-card-desc { font-size:13px; color:var(--muted); line-height:1.6; flex:1; }

/* ══════════════════════════════════════════════════════════════
   RESPONSIVE BREAKPOINTS
══════════════════════════════════════════════════════════════ */

/* Tablet: hide right author col → falls to bottom card */
@media (max-width: 1100px) {
  :root { --col-toc: 200px; --col-author: 0px; --col-gap: 32px; }
  .post-page {
    grid-template-columns: var(--col-toc) 1fr;
    grid-template-areas: "toc content";
  }
  .post-author-col { display: none; }
}

/* Mobile: single column, TOC accordion before content */
@media (max-width: 800px) {
  .post-page {
    grid-template-columns: 1fr;
    grid-template-areas: "content";
    padding: 28px 18px 56px;
  }
  .post-toc-col   { display: none; }   /* desktop TOC hidden */
  .post-author-col { display: none; }
  .toc-mobile     { display: block; }  /* mobile accordion visible */
  .author-card-bottom { flex-direction: column; }
  :root { --fs-body: 16px; }
}

@media (max-width: 560px) {
  .post-hero { padding: 36px 18px 28px; }
  .post-cover-section { padding: 20px 16px 0; }
  .related-section { padding: 0 16px 52px; }
  :root { --fs-body: 15.5px; }
}
  </style>
{% endblock %}

{% block content %}
<article itemscope itemtype="https://schema.org/Article">

  {# Breadcrumbs #}
  <nav class="bc-wrap" aria-label="Breadcrumb">
    <ol class="bc-list" itemscope itemtype="https://schema.org/BreadcrumbList">
      {% for crumb in breadcrumbs %}
        <li class="bc-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          {% if not loop.last %}
            <a href="{{ crumb.url }}" class="bc-link" itemprop="item"><span itemprop="name">{{ crumb.label }}</span></a>
            <span class="bc-sep" aria-hidden="true">›</span>
          {% else %}
            <span class="bc-current" itemprop="name" aria-current="page">{{ crumb.label | truncate(50) }}</span>
          {% endif %}
          <meta itemprop="position" content="{{ loop.index }}" />
        </li>
      {% endfor %}
    </ol>
  </nav>

  {# Hero #}
  <header class="post-hero">
    <div class="post-hero-inner">
      {% if post.category %}
        <a href="/blog/category/{{ post.categorySlug }}" class="post-cat-pill">{{ post.category }}</a>
      {% endif %}
      <h1 itemprop="headline">{{ post.title }}</h1>
      <div class="post-meta-row">
        {% if post.author %}
          <span>By</span>
          <a href="/blog/author/{{ post.author.slug }}" class="post-meta-author-link"
             itemprop="author" itemscope itemtype="https://schema.org/Person">
            {% if post.author.avatar %}
              <img src="{{ post.author.avatar }}" alt="{{ post.author.name }}" class="post-meta-avatar" width="32" height="32" />
            {% else %}
              <div class="post-meta-avatar-init" aria-hidden="true">{{ post.author.name[0] | upper }}</div>
            {% endif %}
            <span itemprop="name">{{ post.author.name }}</span>
          </a>
          <span class="post-meta-sep">·</span>
        {% endif %}
        {% if post.publishedDateFormatted %}
          <time datetime="{{ post.publishedDate }}" itemprop="datePublished">{{ post.publishedDateFormatted }}</time>
          <span class="post-meta-sep">·</span>
        {% endif %}
        <span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-1px;opacity:.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {{ post.readingTime }} min read
        </span>
      </div>
    </div>
  </header>

  {# Cover image #}
  {% if post.coverImage %}
    <div class="post-cover-section">
      <img src="{{ post.coverImage.url }}" alt="{{ post.coverImage.alt }}"
           class="post-cover" width="1200" height="480"
           loading="eager" fetchpriority="high" itemprop="image" />
    </div>
  {% endif %}

  {# 3-column grid #}
  <div class="post-page">

    {# ── LEFT: Desktop TOC ─────────────────────────────────── #}
    <aside class="post-toc-col" aria-label="Table of contents">
      {% if post.toc and post.toc.length > 1 %}
        <nav class="toc-desktop" id="toc-desktop">
          <div class="toc-desktop-header">
            <div class="toc-desktop-title">Contents</div>
          </div>
          <div class="toc-desktop-body" id="toc-desktop-body">
            <ol>
              {% for item in post.toc %}
                <li data-level="{{ item.level }}">
                  <a href="#{{ item.id }}" data-id="{{ item.id }}">{{ item.text }}</a>
                </li>
              {% endfor %}
            </ol>
          </div>
        </nav>
      {% endif %}
    </aside>

    {# ── CENTER: Article content ──────────────────────────── #}
    <div class="post-content-col">

      {# Mobile TOC — accordion, shown before body on small screens #}
      {% if post.toc and post.toc.length > 1 %}
        <nav class="toc-mobile" id="toc-mobile" aria-label="Table of contents">
          <div class="toc-mobile-header" onclick="toggleMobileToc()" role="button" aria-expanded="false" aria-controls="toc-mobile-body">
            <span class="toc-mobile-title">Contents</span>
            <span class="toc-mobile-arrow" id="toc-mobile-arrow">▾</span>
          </div>
          <div class="toc-mobile-body" id="toc-mobile-body" role="region">
            <ol>
              {% for item in post.toc %}
                <li data-level="{{ item.level }}">
                  <a href="#{{ item.id }}">{{ item.text }}</a>
                </li>
              {% endfor %}
            </ol>
          </div>
        </nav>
      {% endif %}

      {# Article body #}
      <div class="post-body" itemprop="articleBody">
        {{ post.content | safe }}
      </div>

      {# Tags #}
      {% if post.tags and post.tags.length %}
        <div class="post-tags" aria-label="Article tags">
          {% for tag in post.tags %}
            {% if tag.slug and not tag.slug.startsWith("hash-") %}
              <a href="/blog/category/{{ tag.slug }}" class="post-tag"># {{ tag.name }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {# Bottom author card — E-E-A-T, always visible #}
      {% if post.author %}
        <aside class="author-card-bottom" aria-label="About the author"
               itemprop="author" itemscope itemtype="https://schema.org/Person">
          {% if post.author.avatar %}
            <img src="{{ post.author.avatar }}" alt="{{ post.author.name }}"
                 class="author-card-bottom-avatar" width="80" height="80" loading="lazy" itemprop="image" />
          {% else %}
            <div class="author-card-bottom-avatar-init" aria-hidden="true">{{ post.author.name[0] | upper }}</div>
          {% endif %}
          <div class="author-card-bottom-meta">
            <div class="author-card-bottom-top">
              <div>
                <div class="author-card-bottom-name" itemprop="name">
                  <a href="/blog/author/{{ post.author.slug }}">{{ post.author.name }}</a>
                </div>
                {% if post.author.role %}
                  <div class="author-card-bottom-role" itemprop="jobTitle">{{ post.author.role }}</div>
                {% endif %}
              </div>
              <div class="author-card-bottom-links">
                {% if post.author.twitter %}
                  <a href="{{ post.author.twitter }}" rel="noopener noreferrer" target="_blank" class="author-card-bottom-link" itemprop="sameAs">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.738-8.85L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    Twitter
                  </a>
                {% endif %}
                {% if post.author.website %}
                  <a href="{{ post.author.website }}" rel="noopener noreferrer" target="_blank" class="author-card-bottom-link" itemprop="url">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    Website
                  </a>
                {% endif %}
              </div>
            </div>
            {% if post.author.bio %}
              <p class="author-card-bottom-bio" itemprop="description">{{ post.author.bio }}</p>
            {% endif %}
            <a href="/blog/author/{{ post.author.slug }}" class="author-card-bottom-more">
              More articles by {{ post.author.name }} →
            </a>
          </div>
        </aside>
      {% endif %}

    </div>{# end center col #}

    {# ── RIGHT: Sticky author sidebar ─────────────────────── #}
    <aside class="post-author-col" aria-label="Author">
      {% if post.author %}
        <div class="sidebar-author">
          {% if post.author.avatar %}
            <img src="{{ post.author.avatar }}" alt="{{ post.author.name }}"
                 class="sidebar-author-avatar" width="72" height="72" loading="lazy" />
          {% else %}
            <div class="sidebar-author-avatar-init" aria-hidden="true">{{ post.author.name[0] | upper }}</div>
          {% endif %}
          <div class="sidebar-author-name">
            <a href="/blog/author/{{ post.author.slug }}">{{ post.author.name }}</a>
          </div>
          {% if post.author.role %}
            <div class="sidebar-author-role">{{ post.author.role }}</div>
          {% endif %}
          {% if post.author.bio %}
            <p class="sidebar-author-bio">{{ post.author.bio | truncate(130) }}</p>
          {% endif %}
          <div class="sidebar-author-links">
            {% if post.author.twitter %}
              <a href="{{ post.author.twitter }}" rel="noopener noreferrer" target="_blank" class="sidebar-author-link">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.738-8.85L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Twitter
              </a>
            {% endif %}
            {% if post.author.website %}
              <a href="{{ post.author.website }}" rel="noopener noreferrer" target="_blank" class="sidebar-author-link">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                Website
              </a>
            {% endif %}
          </div>
          {% if post.author.slug %}
            <a href="/blog/author/{{ post.author.slug }}" class="sidebar-author-more">All articles →</a>
          {% endif %}
        </div>
      {% endif %}
    </aside>

  </div>{# end post-page grid #}

</article>

{# Related posts #}
{% if relatedPosts and relatedPosts.length %}
  <section class="related-section" aria-label="Related articles">
    <h2 class="related-heading">Keep Learning</h2>
    <div class="related-grid">
      {% for rp in relatedPosts %}
        <a href="/blog/{{ rp.slug }}" class="rp-card">
          {% if rp.coverImage %}
            <img src="{{ rp.coverImage.url }}" alt="{{ rp.coverImage.alt }}" class="rp-card-img" loading="lazy" />
          {% else %}
            <div class="rp-card-img-placeholder" aria-hidden="true">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          {% endif %}
          <div class="rp-card-body">
            {% if rp.category %}<div class="rp-card-cat">{{ rp.category }}</div>{% endif %}
            <div class="rp-card-title">{{ rp.title }}</div>
            {% if rp.description %}<div class="rp-card-desc">{{ rp.description | truncate(100) }}</div>{% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}

{% endblock %}

{% block scripts %}
<script>
/* ── Mobile TOC toggle ──────────────────────────────────── */
function toggleMobileToc() {
  try {
    const body   = document.getElementById('toc-mobile-body');
    const arrow  = document.getElementById('toc-mobile-arrow');
    const header = body?.previousElementSibling;
    if (!body) return;
    const isOpen = body.classList.toggle('open');
    if (arrow)  arrow.classList.toggle('open', isOpen);
    if (header) header.setAttribute('aria-expanded', String(isOpen));
  } catch(e) {}
}

/* ── Desktop TOC active-link highlight on scroll ────────── */
(function initTocScroll() {
  const links = document.querySelectorAll('#toc-desktop a[data-id]');
  if (!links.length) return;

  const headings = [];
  links.forEach(a => {
    const el = document.getElementById(a.dataset.id);
    if (el) headings.push({ el, a });
  });
  if (!headings.length) return;

  function update() {
    try {
      const scrollY = window.scrollY + 110;
      let active = headings[0];
      for (const h of headings) {
        if (h.el.getBoundingClientRect().top + window.scrollY <= scrollY) active = h;
        else break;
      }
      links.forEach(l => l.classList.remove('toc-active'));
      if (active) {
        active.a.classList.add('toc-active');
        // Auto-scroll TOC body to keep active link visible
        const body = document.getElementById('toc-desktop-body');
        if (body) {
          const linkTop  = active.a.offsetTop;
          const bodyH    = body.clientHeight;
          const scrollT  = body.scrollTop;
          if (linkTop < scrollT + 20 || linkTop > scrollT + bodyH - 40) {
            body.scrollTo({ top: linkTop - bodyH / 2, behavior: 'smooth' });
          }
        }
      }
    } catch(e) {}
  }

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { update(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });
  update();
})();

/* ── Smooth scroll with navbar offset for all anchor links ── */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    try {
      const id = a.getAttribute('href').slice(1);
      if (!id) return;
      const el = document.getElementById(id);
      if (!el) return;
      e.preventDefault();
      const offset = 96;
      const top = el.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
      // Close mobile TOC after click
      const mob = document.getElementById('toc-mobile-body');
      if (mob?.classList.contains('open')) toggleMobileToc();
    } catch(e) {}
  });
});
</script>
{% endblock %}
