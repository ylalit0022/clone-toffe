{% extends "../../layouts/base.njk" %}

{% block title %}Create Account – Tranzo{% endblock %}
{% block metaDesc %}Create a free Tranzo account.{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ siteUrl }}/auth/register" />{% endblock %}

{% block head %}
<style>
  .auth-wrap { min-height:calc(100vh - 120px); display:flex; align-items:center; justify-content:center; padding:2rem 1rem; }
  .auth-card { width:100%; max-width:420px; background:var(--surface); border:1px solid var(--border); border-radius:var(--r); box-shadow:var(--shadow-md); padding:2.25rem 2rem; }
  .auth-logo { text-align:center; margin-bottom:1.75rem; }
  .auth-logo a { font-family:'Space Grotesk',sans-serif; font-size:1.6rem; font-weight:700; color:var(--text); text-decoration:none; }
  .auth-logo .dot { color:var(--em); }
  .auth-title { font-family:'Space Grotesk',sans-serif; font-size:1.25rem; font-weight:700; color:var(--text); text-align:center; margin-bottom:.25rem; }
  .auth-sub { font-size:.875rem; color:var(--muted); text-align:center; margin-bottom:1.75rem; }
  .form-label { font-size:.8125rem; font-weight:600; color:var(--muted); margin-bottom:.4rem; display:block; }
  .form-input { width:100%; padding:.65rem .9rem; border:1.5px solid var(--border); border-radius:var(--rSm); background:var(--bg); color:var(--text); font-size:.9375rem; font-family:inherit; outline:none; transition:border-color .2s; }
  .form-input:focus { border-color:var(--em); box-shadow:0 0 0 3px var(--emGlow); }
  .form-group { margin-bottom:1.1rem; }
  .btn-auth { width:100%; padding:.7rem; background:var(--em); color:#fff; border:none; border-radius:var(--rSm); font-size:.9375rem; font-weight:600; font-family:inherit; cursor:pointer; transition:background .2s, transform .1s; margin-top:.5rem; }
  .btn-auth:hover { background:var(--emDark); }
  .btn-auth:active { transform:scale(.98); }
  .btn-auth:disabled { opacity:.6; cursor:not-allowed; }
  .auth-footer { text-align:center; margin-top:1.25rem; font-size:.875rem; color:var(--muted); }
  .auth-footer a { color:var(--em); font-weight:600; text-decoration:none; }
  .auth-footer a:hover { text-decoration:underline; }
  .alert-box { padding:.7rem .9rem; border-radius:var(--rSm); font-size:.875rem; margin-bottom:1.1rem; }
  .alert-error { background:var(--roseLight); color:var(--rose); border:1px solid rgba(239,68,68,.2); }
  .spinner { display:none; width:16px; height:16px; border:2px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation:spin .6s linear infinite; margin:0 auto; }
  @keyframes spin { to { transform:rotate(360deg); } }

  /* ── Password strength meter ── */
  .pw-strength { margin-top:.5rem; }
  .pw-bar-track { height:4px; background:var(--surfaceHi); border-radius:99px; overflow:hidden; }
  .pw-bar-fill  { height:100%; width:0; border-radius:99px; transition:width .3s, background .3s; }
  .pw-rules { display:flex; flex-wrap:wrap; gap:.3rem .75rem; margin-top:.5rem; }
  .pw-rule  { font-size:.75rem; color:var(--muted2); display:flex; align-items:center; gap:.25rem; }
  .pw-rule.ok { color:var(--em); }
  .pw-rule .dot { width:6px; height:6px; border-radius:50%; background:currentColor; flex-shrink:0; }
</style>
{% endblock %}

{% block content %}
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo"><a href="/">&#9889; Tran<span class="dot">zo</span></a></div>
    <div class="auth-title">Create account</div>
    <div class="auth-sub">Free forever · No upload · 100% P2P</div>

    <div id="alertBox" style="display:none" class="alert-box alert-error"></div>

    <div class="form-group">
      <label class="form-label" for="name">Display name</label>
      <input class="form-input" type="text" id="name" placeholder="Your name" autocomplete="name" />
    </div>
    <div class="form-group">
      <label class="form-label" for="email">Email address</label>
      <input class="form-input" type="email" id="email" placeholder="you@example.com" autocomplete="email" required />
    </div>
    <div class="form-group">
      <label class="form-label" for="password">Password</label>
      <input class="form-input" type="password" id="password" placeholder="Create a strong password" autocomplete="new-password" oninput="checkStrength(this.value)" required />
      <!-- Strength meter -->
      <div class="pw-strength">
        <div class="pw-bar-track"><div class="pw-bar-fill" id="pwBar"></div></div>
        <div class="pw-rules">
          <span class="pw-rule" id="r-len"><span class="dot"></span>8+ chars</span>
          <span class="pw-rule" id="r-upper"><span class="dot"></span>Uppercase</span>
          <span class="pw-rule" id="r-num"><span class="dot"></span>Number</span>
          <span class="pw-rule" id="r-special"><span class="dot"></span>Special char</span>
        </div>
      </div>
    </div>

    <button class="btn-auth" id="regBtn" onclick="doRegister()">
      <span id="btnText">Create account</span>
      <span class="spinner" id="btnSpinner"></span>
    </button>

    <div class="auth-footer">Already have an account? <a href="/auth/login">Sign in</a></div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
// ── Password strength checker ─────────────────────────────────
function checkStrength(pw) {
  const rules = {
    "r-len":     pw.length >= 8,
    "r-upper":   /[A-Z]/.test(pw),
    "r-num":     /[0-9]/.test(pw),
    "r-special": /[^A-Za-z0-9]/.test(pw),
  };
  const passed = Object.values(rules).filter(Boolean).length;
  Object.entries(rules).forEach(([id, ok]) => {
    document.getElementById(id).classList.toggle("ok", ok);
  });
  const bar    = document.getElementById("pwBar");
  const colors = ["#EF4444","#F59E0B","#F59E0B","#059669","#059669"];
  bar.style.width      = `${passed * 25}%`;
  bar.style.background = colors[passed];
}

// ── Register ──────────────────────────────────────────────────
async function doRegister() {
  const name  = document.getElementById("name").value.trim();
  const email = document.getElementById("email").value.trim();
  const pw    = document.getElementById("password").value;
  const btn   = document.getElementById("regBtn");
  const txt   = document.getElementById("btnText");
  const spin  = document.getElementById("btnSpinner");

  if (!email || !pw) { showAlert("Email and password are required."); return; }

  btn.disabled = true;
  txt.style.display = "none";
  spin.style.display = "block";
  document.getElementById("alertBox").style.display = "none";

  try {
    const r = await fetch("/auth/register", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, email, password: pw }),
    });
    const d = await r.json();
    if (d.ok) {
      window.location.href = d.redirect || "/";
    } else {
      showAlert(d.error || "Registration failed.");
    }
  } catch { showAlert("Network error. Please try again."); }
  finally {
    btn.disabled = false;
    txt.style.display = "";
    spin.style.display = "none";
  }
}

function showAlert(msg) {
  const el = document.getElementById("alertBox");
  el.textContent = msg;
  el.style.display = "block";
}

document.addEventListener("keydown", e => { if (e.key === "Enter") doRegister(); });
</script>
{% endblock %}
