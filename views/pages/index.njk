{% extends "../layouts/base.njk" %}

{% block title %}Tranzo – Free P2P File Transfer, No Upload, No Limits{% endblock %}
{% block metaDesc %}Transfer files directly between devices for free using WebRTC. No cloud, no signup, no size limits. 100% private P2P file sharing.{% endblock %}
{% block canonical %}<link rel="canonical" href="https://share.rumnnlg.com/" />{% endblock %}
{% block ogTitle %}Tranzo – Free P2P File Transfer{% endblock %}
{% block ogUrl %}https://share.rumnnlg.com/{% endblock %}

{# ── INDEX overrides the navbar block with the connection-pill nav ── #}
{% block navbar %}
<nav class="nav-bar">
  <div class="container-lg">
    <div class="nav-inner">

      <a href="/" class="nav-logo">
        <span class="nav-logo-icon">&#9889;</span>
        Tran<span class="dot">zo</span>
      </a>

      <div class="nav-right">
        <!-- Status pill: show dot+text on sm+, dot-only on xs via CSS above -->
        <div class="conn-pill">
          <span class="conn-dot" id="connDot"></span>
          <span id="status">Not Connected</span>
        </div>
        <!-- P2P badge: hidden on xs -->
        <span class="nav-badge d-none d-sm-inline-block">P2P</span>
      </div>

    </div>
  </div>
</nav>
{% endblock %}

{# ── INDEX overrides the footer with the simple original footer ── #}
{% block footer %}
<footer class="page-footer py-4">
  <div class="container-lg">
    <div class="row align-items-center gy-3">
      <div class="col-12 col-sm-auto">
        <div class="d-flex align-items-center gap-2">
          <div class="footer-icon">&#9889;</div>
          <div>
            <div class="footer-name">Tranzo</div>
            <div class="footer-tag">Files never touch our servers.</div>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm">
        <div class="footer-links d-flex flex-wrap gap-3 justify-content-sm-end justify-content-center align-items-center">
