<!-- BRIDGE 1: native progress.value -> visual fill bar (kept for compat) -->
<script>
(function(){
  var native = document.getElementById('progressBar');
  var fill   = document.getElementById('progressFill');
  if (!native || !fill) return;
  var proto = HTMLProgressElement.prototype;
  var desc  = Object.getOwnPropertyDescriptor(proto, 'value');
  if (!desc || Object.getOwnPropertyDescriptor(native, 'value')) return;
  Object.defineProperty(native, 'value', {
    get: function()  { return desc.get.call(this); },
    set: function(v) {
      desc.set.call(this, v);
      fill.style.width = ((v / this.max) * 100) + '%';
    }
  });
})();
</script>

<!-- BRIDGE 2: drop zone drag highlight -->
<script>
(function(){
  var dz = document.getElementById('dropZone');
  if (!dz) return;
  ['dragenter','dragover'].forEach(function(ev) {
    dz.addEventListener(ev, function(e) { e.preventDefault(); dz.classList.add('dragover'); });
  });
  ['dragleave','drop'].forEach(function(ev) {
    dz.addEventListener(ev, function() { dz.classList.remove('dragover'); });
  });
})();
</script>

<!--
  BRIDGE 3: Progressive Reveal Interceptor

  script.js sets element.style.display = 'block'|'none'
  on #shareLinkCard and #chatSection.

  We Proxy .style so those writes toggle .is-visible on the
  parent .reveal-panel -> smooth CSS max-height transition.

  filePanel revealed by EITHER shareLinkCard (sender)
  OR chatSection (receiver) — both sides get the file panel.

  script.js NOT modified. All IDs intact. SEO safe.
-->
<script>
(function() {

  function interceptDisplay(el, panel, onShow, onHide) {
    if (!el || !panel) return;
    var real = el.style;
    var proxy = new Proxy(real, {
      set: function(t, prop, val) {
        if (prop === 'display') {
          var show = val !== 'none' && val !== '';
          panel.classList.toggle('is-visible', show);
          if (show  && onShow) onShow();
          if (!show && onHide) onHide();
          try { t[prop] = val; } catch(e){}
          return true;
        }
        try { t[prop] = val; } catch(e){}
        return true;
      },
      get: function(t, prop) {
        var v = t[prop];
        return typeof v === 'function' ? v.bind(t) : v;
      }
    });
    Object.defineProperty(el, 'style', { get: function(){ return proxy; }, configurable: true });
  }

  function compactHero() {
    var h = document.getElementById('heroSection');
    if (h) h.classList.add('hero-compact');
  }

  function revealFilePanel() {
    var fp = document.getElementById('filePanel');
    if (fp) fp.classList.add('is-visible');
  }

  function hideFilePanel() {
    var slc = document.getElementById('shareLinkCard');
    var cs  = document.getElementById('chatSection');
    var slcHidden = !slc || slc.style.display === 'none' || slc.style.display === '';
    var csHidden  = !cs  || cs.style.display  === 'none' || cs.style.display  === '';
    if (slcHidden && csHidden) {
      var fp = document.getElementById('filePanel');
      if (fp) fp.classList.remove('is-visible');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {

    /* Sender path */
    interceptDisplay(
      document.getElementById('shareLinkCard'),
      document.getElementById('shareLinkPanel'),
      function() { revealFilePanel(); compactHero(); },
      function() { hideFilePanel(); }
    );

    /* Receiver path */
    interceptDisplay(
      document.getElementById('chatSection'),
      document.getElementById('chatPanel'),
      function() { revealFilePanel(); compactHero(); },
      function() { hideFilePanel(); }
    );

    /* Instant hero compact on Create/Join */
    ['createBtn','joinBtn'].forEach(function(id) {
      var btn = document.getElementById(id);
      if (btn) btn.addEventListener('click', compactHero);
    });

    /* multiroom.js panels — no interceptor needed, multiroom.js toggles
       is-visible directly on #membersPanel / #scorePanel */

  });
})();
</script>

