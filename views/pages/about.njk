{% extends "../layouts/base.njk" %}

{% block title %}About Tranzo – Free P2P File Transfer{% endblock %}
{% block metaDesc %}Learn about Tranzo, the free WebRTC-powered peer-to-peer file transfer tool. No cloud, no signup, 100% private.{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ siteUrl }}/about" />{% endblock %}
{% block ogTitle %}About Tranzo – Free P2P File Transfer{% endblock %}
{% block ogUrl %}{{ siteUrl }}/about{% endblock %}

{% block adTop %}
<div class="container-lg pt-3">
  <div class="ad-slot ad-slot-leaderboard">
    <!-- AdSense Leaderboard 728x90 — replace with your ad unit -->
    <iframe src="about:blank" title="Advertisement" aria-label="Advertisement" scrolling="no"></iframe>
  </div>
</div>
{% endblock %}

{% block content %}
<main class="content-page">
  <div class="container-lg">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">

        <div class="page-eyebrow">&#9889; Our Story</div>
        <h1>About <span class="grad">Tranzo</span></h1>
        <p class="lead">Tranzo was built on a simple belief: sharing files between your own devices shouldn't require uploading them to a stranger's server first.</p>

        <!-- In-content ad -->
        <div class="ad-slot ad-slot-rect mb-4">
          <iframe src="about:blank" title="Advertisement" aria-label="Advertisement" scrolling="no"></iframe>
        </div>

        <h2>What We Built</h2>
        <p>Tranzo is a browser-based, peer-to-peer file transfer tool powered by <strong>WebRTC</strong> — the same real-time communication technology used in video calls. When you send a file, it travels directly from your browser to the recipient's browser. Our server only brokers the initial connection and never touches your data.</p>

        <div class="row g-3 my-2">
          <div class="col-12 col-sm-6">
            <div class="info-card d-flex gap-3 align-items-start">
              <div class="feature-icon">&#128274;</div>
              <div>
                <h3 class="mb-1" style="margin-top:0;">End-to-End Encrypted</h3>
                <p class="mb-0" style="font-size:14px;">WebRTC uses DTLS and SRTP encryption by default. Your files are encrypted in transit.</p>
              </div>
            </div>
          </div>
          <div class="col-12 col-sm-6">
            <div class="info-card d-flex gap-3 align-items-start">
              <div class="feature-icon amb">&#128515;</div>
              <div>
                <h3 class="mb-1" style="margin-top:0;">Always Free</h3>
                <p class="mb-0" style="font-size:14px;">No pricing tiers, no file size limits, no watermarks. Tranzo is free for everyone, forever.</p>
              </div>
            </div>
          </div>
          <div class="col-12 col-sm-6">
            <div class="info-card d-flex gap-3 align-items-start">
              <div class="feature-icon">&#128241;</div>
              <div>
                <h3 class="mb-1" style="margin-top:0;">Any Device</h3>
                <p class="mb-0" style="font-size:14px;">Works on Android, iPhone, Windows, Mac, Linux — any modern browser with no app install required.</p>
              </div>
            </div>
          </div>
          <div class="col-12 col-sm-6">
            <div class="info-card d-flex gap-3 align-items-start">
              <div class="feature-icon">&#9729;</div>
              <div>
                <h3 class="mb-1" style="margin-top:0;">Zero Cloud Storage</h3>
                <p class="mb-0" style="font-size:14px;">Files never land on our servers. They go directly from sender to receiver over a peer connection.</p>
              </div>
            </div>
          </div>
        </div>

        <h2>Why We Made It</h2>
        <p>We got tired of slow upload limits, mandatory accounts, and wondering where our files ended up after "deletion." So we built the tool we always wanted: fast, private, and completely in the browser.</p>
        <p>Tranzo is open source. If you find a bug or want to contribute, check out the project on <a href="https://github.com/ylalit0022/clone-toffe" target="_blank" rel="noopener">GitHub</a>.</p>

        <h2>Contact</h2>
        <p>Have a question or feedback? Head to our <a href="/contact">contact page</a> — we read every message.</p>

      </div>
    </div>
  </div>
</main>
{% endblock %}
