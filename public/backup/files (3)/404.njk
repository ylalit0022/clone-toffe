{% extends "../layouts/base.njk" %}

{% block title %}404 – Page Not Found | Tranzo{% endblock %}
{% block metaDesc %}The page you're looking for doesn't exist. Go back to Tranzo and start a free peer-to-peer file transfer.{% endblock %}
{% block canonical %}<link rel="canonical" href="https://share.rumnnlg.com/404" />{% endblock %}

{% block content %}
<main class="content-page" style="display:flex;align-items:center;justify-content:center;min-height:60vh;text-align:center;">
  <div class="container-lg">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">

        <!-- Big 404 -->
        <div style="font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(5rem,18vw,9rem);line-height:1;letter-spacing:-.05em;background:linear-gradient(100deg,var(--em) 0%,#10B981 45%,var(--amb) 100%);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:12px;">
          404
        </div>

        <h1 style="font-size:clamp(1.4rem,4vw,2rem);margin-bottom:12px;">
          Page Not Found
        </h1>
        <p style="color:var(--muted);max-width:380px;margin:0 auto 32px;line-height:1.7;">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
          <a href="/" class="btn-em" style="text-decoration:none;">&#9889; Go to Tranzo</a>
          <a href="/how-it-works" class="btn-ghost" style="text-decoration:none;">How It Works</a>
        </div>

        <div style="margin-top:48px;display:flex;flex-wrap:wrap;justify-content:center;gap:12px;">
          <a href="/faq" style="font-size:13px;color:var(--muted);text-decoration:none;padding:6px 14px;border:1px solid var(--border);border-radius:999px;">FAQ</a>
          <a href="/security" style="font-size:13px;color:var(--muted);text-decoration:none;padding:6px 14px;border:1px solid var(--border);border-radius:999px;">Security</a>
          <a href="/about" style="font-size:13px;color:var(--muted);text-decoration:none;padding:6px 14px;border:1px solid var(--border);border-radius:999px;">About</a>
          <a href="/contact" style="font-size:13px;color:var(--muted);text-decoration:none;padding:6px 14px;border:1px solid var(--border);border-radius:999px;">Contact</a>
        </div>

      </div>
    </div>
  </div>
</main>
{% endblock %}
