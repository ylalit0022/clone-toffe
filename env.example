# ─── Site Domain ─────────────────────────────────────────────────────────────
# Change this ONE variable when moving to a new domain.
# All canonical URLs, OG tags, sitemaps, and robots.txt update automatically.
SITE_URL=https://yourdomain.com

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/tranzo
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/tranzo
MONGODB_URI=mongodb://127.0.0.1:27017/tranzo

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── TURN / ICE credentials ───────────────────────────────────────────────────
INDIA_TURN_HOST=
INDIA_TURN_USER=
INDIA_TURN_PASS=

METERED_USER=
METERED_PASS=
